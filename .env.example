# Frontend environment examples

# Default local backend (desktop browser)
# NOTE: Xcode/Android Studio (Capacitor) local dev is pinned to port :8001 in code.
# REACT_APP_LOCAL_API_BASE impacts desktop browser dev; for real-device testing, use
# REACT_APP_USE_DEVICE_API=true with REACT_APP_DEVICE_API_BASE=http://YOUR_LAN_IP:8001.
REACT_APP_API_BASE=http://localhost:8001
REACT_APP_LOCAL_API_BASE=http://localhost:8001

# Device testing toggle (mobile/tablet)
# When true, API_BASE_URL will use REACT_APP_DEVICE_API_BASE instead of localhost.
REACT_APP_USE_DEVICE_API=false
REACT_APP_DEVICE_API_BASE=http://192.168.1.42:8001

# Force using REACT_APP_API_BASE even on localhost (useful for dev/prod tests).
REACT_APP_FORCE_API_BASE=false

# Capacitor iOS loopback retry (localhost <-> 127.0.0.1)
# Default false to avoid implicit host switching in native iOS.
REACT_APP_CAPACITOR_IOS_LOOPBACK_RETRY=false

# Pilot app store listing URLs (used for official store badges in the pilot promo modal)
# IMPORTANT: Don't point store badges at a homepage-use the real listing URLs.
REACT_APP_PILOT_APP_STORE_URL=
REACT_APP_PILOT_GOOGLE_PLAY_URL=

# Main (consumer) app store listing URLs (used for landing page footer badges)
# If unset, the UI will fall back to the pilot values above.
REACT_APP_APP_STORE_URL=
# Canonical listing URL:
#   https://play.google.com/store/apps/details?id=com.errandbridge.app
# If your app isn't public yet, you can temporarily use the internal testing opt-in URL:
#   https://play.google.com/apps/test/com.errandbridge.app/<trackId>
REACT_APP_GOOGLE_PLAY_URL=

# Optional public review URL (shown after completing an errand)
# Example: https://g.page/r/your-google-business/review
REACT_APP_PUBLIC_REVIEW_URL=

# Google Sign-In (frontend)
# Use a dedicated pilot web client for `https://pilot.errandbridge.com` so the
# pilot portal does not inherit the main site's Google authorized origins.
# REACT_APP_GOOGLE_CLIENT_ID=935525000080-2mq79rsqeion43g3ln2q3954ua6jgt6h.apps.googleusercontent.com
# Optional dedicated customer web client id (falls back to REACT_APP_GOOGLE_CLIENT_ID)
# REACT_APP_GOOGLE_CUSTOMER_CLIENT_ID=customer-client-id.apps.googleusercontent.com
# REACT_APP_GOOGLE_PILOT_CLIENT_ID=pilot-client-id.apps.googleusercontent.com
# REACT_APP_GOOGLE_PILOT_AUTH_ENABLED=true
# Optional: pilot-specific allowlist for showing the Google button (falls back to REACT_APP_GOOGLE_AUTH_HOSTS)
# REACT_APP_GOOGLE_PILOT_AUTH_HOSTS=pilot.errandbridge.com
# REACT_APP_GOOGLE_ANDROID_CLIENT_ID=935525000080-7lt8gto02f76fqv6dtde05utodvcdim8.apps.googleusercontent.com
# REACT_APP_GOOGLE_IOS_CLIENT_ID=935525000080-147tgo20044ssforvkofbfeqo52ou115.apps.googleusercontent.com

# Google OAuth redirect flow (frontend)
# When enabled, the customer login/signup page uses backend-managed Google OAuth via
#   /auth/oauth/google/start (popup + postMessage)
# instead of the Google Identity Services credential widget.
REACT_APP_GOOGLE_REDIRECT_AUTH_ENABLED=true

# Apple OAuth (frontend toggle)
# Apple uses a backend-managed OAuth flow via /auth/oauth/apple/start.
# Set to true (and configure backend Apple env vars, including APPLE_PRIVATE_KEY as PEM text or a .p8 path)
# to show the buttons in the login/signup modal.
REACT_APP_APPLE_AUTH_ENABLED=false
REACT_APP_APPLE_AUTH_HOSTS=errandbridge.com,www.errandbridge.com,pilot.errandbridge.com

# Optional: pilot-only Apple enablement/host allowlist (falls back to REACT_APP_APPLE_AUTH_*)
# REACT_APP_APPLE_PILOT_AUTH_ENABLED=true
# REACT_APP_APPLE_PILOT_AUTH_HOSTS=pilot.errandbridge.com

# Stripe (frontend)
# REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_...
# REACT_APP_PLUS_SUBSCRIPTION_LABEL=£29 / month

# Payments testing (frontend)
# Controls whether "$1 test charge" + "Free test pass" appear in the Plan picker.
# In development builds these options will still appear by default.
REACT_APP_ALLOW_TEST_PAYMENTS=false

# Pricing uplift multiplier applied to all one-time errand prices shown/charged.
# Default is 1.3 (30% increase).
# REACT_APP_PRICE_UPLIFT_MULTIPLIER=1.3

# Toxi (frontend)
# Enables the additive OpenAI structured assist for request_builder mode.
REACT_APP_TOXI_OPENAI_ENABLED=false

# Internal-only pricing / economics sections (Pricing modal)
# Set true in dev to reveal internal pricing details.
REACT_APP_SHOW_INTERNAL_PRICING=false
