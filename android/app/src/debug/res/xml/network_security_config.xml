<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network security config.
  Allows http:// traffic for local development endpoints.
-->
<network-security-config>
  <!--
    Debug-only: allow cleartext HTTP to any host.

    Why:
    - Physical devices cannot reach your Mac via localhost.
    - Your dev server/API may be on a LAN IP (e.g. http://192.168.x.x:3002).

    NOTE: This file is under src/debug/, so release builds remain strict.
  -->
  <base-config cleartextTrafficPermitted="true" />

  <!-- Keep explicit local hosts for clarity (redundant with base-config). -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="true">localhost</domain>
    <domain includeSubdomains="false">127.0.0.1</domain>
    <!-- Android emulator host loopback -->
    <domain includeSubdomains="false">10.0.2.2</domain>
    <domain includeSubdomains="false">10.0.3.2</domain>
  </domain-config>
</network-security-config>
