                  fontSize: 15,
                  cursor: 'pointer',
                  transition: 'background 0.2s'
                }}
                onMouseEnter={(e) => e.target.style.background = '#1d4ed8'}
                onMouseLeave={(e) => e.target.style.background = '#2563eb'}
              >
                Close
              </button>
            </div>
          </div>
        </div>
      )}
      
      {/* Puzzle Modal */}
      {puzzleOpen && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 400, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => setPuzzleOpen(false)} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 12 }}>Puzzle Time!</h3>
            <div style={{ marginBottom: 16, fontSize: 17 }}>{PUZZLES[puzzleIdx].q}</div>
            <form onSubmit={handlePuzzleSubmit}>
              <input
                type="text"
                value={puzzleInput}
                onChange={e => setPuzzleInput(e.target.value)}
                disabled={puzzleShowAnswer}
                placeholder="Your answer..."
                style={{ width: '100%', padding: 8, fontSize: 16, borderRadius: 8, border: '1.5px solid #bfc2d9', marginBottom: 10 }}
              />
              <button type="submit" style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '8px 18px', fontWeight: 600, fontSize: 16, cursor: 'pointer', marginRight: 8 }} disabled={puzzleShowAnswer}>Submit</button>
              <button type="button" style={{ background: '#f3f4f6', color: '#2563eb', border: 'none', borderRadius: 8, padding: '8px 18px', fontWeight: 600, fontSize: 16, cursor: 'pointer' }} onClick={handleNextPuzzle}>Next</button>
            </form>
            <div style={{ marginTop: 10, color: '#e74c3c', fontWeight: 600 }}>
              {puzzleShowAnswer && (
                <span>Answer: {PUZZLES[puzzleIdx].a}</span>
              )}
            </div>
            <div style={{ marginTop: 8, color: '#888', fontSize: 14 }}>Attempts: {puzzleAttempts} / 3</div>
          </div>
        </div>
      )}

      {/* Settings Modal */}
      {settingsOpen && !showChangePassword && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 400, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => setSettingsOpen(false)} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 6 }}>⚙️ Account Settings</h3>
            <p style={{ fontSize: 13, color: '#666', marginBottom: 16 }}>Update your account information and security</p>
            <form onSubmit={handleSaveSettings}>
              <div style={{ marginBottom: 12 }}>
                <label style={{ fontWeight: 600, fontSize: 13 }}>First Name</label>
                <input type="text" value={editFirstName} readOnly style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box', backgroundColor: '#f3f4f6', color: '#666', cursor: 'not-allowed' }} />
                <label style={{ fontWeight: 600, fontSize: 13 }}>Last Name</label>
                <input type="text" value={editLastName} readOnly style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box', backgroundColor: '#f3f4f6', color: '#666', cursor: 'not-allowed' }} />
                <label style={{ fontWeight: 600, fontSize: 13 }}>Email</label>
                <input type="email" value={editEmail} onChange={e => setEditEmail(e.target.value)} style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                <label style={{ fontWeight: 600, fontSize: 13 }}>Phone</label>
                <input type="tel" value={editPhone} onChange={e => setEditPhone(e.target.value)} style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} />
                <label style={{ fontWeight: 600, fontSize: 13 }}>Address</label>
                <input type="text" value={editAddress} onChange={e => setEditAddress(e.target.value)} style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} placeholder="Street address" />
                <label style={{ fontWeight: 600, fontSize: 13 }}>City</label>
                <input type="text" value={editCity} onChange={e => setEditCity(e.target.value)} style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                <label style={{ fontWeight: 600, fontSize: 13 }}>Country</label>
                <input type="text" value={editCountry} onChange={e => setEditCountry(e.target.value)} style={{ width: '100%', marginBottom: 8, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                <label style={{ fontWeight: 600, fontSize: 13 }}>Zip/Postcode</label>
                <input type="text" value={editPostcode} onChange={e => setEditPostcode(e.target.value)} style={{ width: '100%', marginBottom: 12, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
              </div>
              <button type="submit" style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer' }}>💾 Save Changes</button>
            </form>
            <button onClick={() => setShowChangePassword(true)} style={{ background: '#f3f4f6', color: '#2563eb', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 14, width: '100%', marginBottom: 8, cursor: 'pointer' }}>🔐 Change Password</button>
            <button onClick={handleDeactivateAccount} style={{ background: '#fee2e2', color: '#dc2626', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 14, width: '100%', cursor: 'pointer' }}>🗑️ Deactivate Account</button>
          </div>
        </div>
      )}

      {/* Change Password Modal */}
      {settingsOpen && showChangePassword && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 400, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => setShowChangePassword(false)} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 12 }}>Change Password</h3>
            <form onSubmit={handleChangePassword}>
              {changePasswordError && <div style={{ color: '#dc2626', fontSize: 14, marginBottom: 12, padding: 10, background: '#fee2e2', borderRadius: 6 }}>{changePasswordError}</div>}
              {changePasswordSuccess && <div style={{ color: '#059669', fontSize: 14, marginBottom: 12, padding: 10, background: '#d1fae5', borderRadius: 6 }}>{changePasswordSuccess}</div>}
              
              <div style={{ marginBottom: 12 }}>
                <label style={{ fontWeight: 600, fontSize: 13, display: 'block', marginBottom: 6 }}>Current Password</label>
                <div style={{ position: 'relative', marginBottom: 12 }}>
                  <input 
                    type={showCurrentPasswordField ? "text" : "password"} 
                    value={changePasswordCurrentPassword} 
                    onChange={e => setChangePasswordCurrentPassword(e.target.value)} 
                    placeholder="Enter current password"
                    style={{ width: '100%', padding: 10, paddingRight: 40, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} 
                    required 
                  />
                  <button 
                    type="button" 
                    style={{ position: 'absolute', right: 12, top: 10, background: 'none', border: 'none', color: '#2563eb', fontWeight: 600, cursor: 'pointer', fontSize: 13 }} 
                    onClick={() => setShowCurrentPasswordField(v => !v)}
                  >
                    {showCurrentPasswordField ? 'Hide' : 'Show'}
                  </button>
                </div>
                
                <label style={{ fontWeight: 600, fontSize: 13, display: 'block', marginBottom: 6 }}>New Password</label>
                <div style={{ position: 'relative', marginBottom: 12 }}>
                  <input 
                    type={showNewPasswordField ? "text" : "password"} 
                    value={changePasswordNewPassword} 
                    onChange={e => setChangePasswordNewPassword(e.target.value)} 
                    placeholder="Enter new password (min 8 characters)"
                    style={{ width: '100%', padding: 10, paddingRight: 40, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} 
                    required 
                  />
                  <button 
                    type="button" 
                    style={{ position: 'absolute', right: 12, top: 10, background: 'none', border: 'none', color: '#2563eb', fontWeight: 600, cursor: 'pointer', fontSize: 13 }} 
                    onClick={() => setShowNewPasswordField(v => !v)}
                  >
                    {showNewPasswordField ? 'Hide' : 'Show'}
                  </button>
                </div>
                
                <label style={{ fontWeight: 600, fontSize: 13, display: 'block', marginBottom: 6 }}>Confirm Password</label>
                <div style={{ position: 'relative' }}>
                  <input 
                    type={showConfirmPasswordField ? "text" : "password"} 
                    value={changePasswordConfirmPassword} 
                    onChange={e => setChangePasswordConfirmPassword(e.target.value)} 
                    placeholder="Confirm new password"
                    style={{ width: '100%', padding: 10, paddingRight: 40, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} 
                    required 
                  />
                  <button 
                    type="button" 
                    style={{ position: 'absolute', right: 12, top: 10, background: 'none', border: 'none', color: '#2563eb', fontWeight: 600, cursor: 'pointer', fontSize: 13 }} 
                    onClick={() => setShowConfirmPasswordField(v => !v)}
                  >
                    {showConfirmPasswordField ? 'Hide' : 'Show'}
                  </button>
                </div>
              </div>
              
              <button type="submit" style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer' }}>Update Password</button>
              <button type="button" onClick={() => setShowChangePassword(false)} style={{ background: '#f3f4f6', color: '#666', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 14, width: '100%', cursor: 'pointer' }}>Cancel</button>
            </form>
          </div>
        </div>
      )}


      {/* Auth Modal */}
      {authModalOpen && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 2000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 400, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => { setAuthModalOpen(false); setResetPwMode(false); }} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 12 }}>
              {resetPwMode ? 'Reset Password' : (authMode === 'login' ? 'Login' : 'Sign Up')}
            </h3>
            <form onSubmit={handleAuthSubmit}>
              {resetPwMode ? (
                <>
                  <input type="email" value={resetPwEmail} onChange={e => setResetPwEmail(e.target.value)} placeholder="Enter your email" style={{ width: '100%', marginBottom: 12, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9' }} required />
                  <div style={{ marginBottom: 12 }}>
                    <label><input type="radio" checked={resetPwMethod === 'link'} onChange={() => setResetPwMethod('link')} /> Email link</label>
                    <label style={{ marginLeft: 16 }}><input type="radio" checked={resetPwMethod === 'otp'} onChange={() => setResetPwMethod('otp')} /> OTP</label>
                  </div>
                  {!resetPwOtpSent ? (
                    <button type="button" style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer' }} onClick={() => {
                      setResetPwOtpSent(true);
                      if (resetPwMethod === 'otp') setResetPwOtp('123456');
                      // ...existing code...
                    }}>Send {resetPwMethod === 'otp' ? 'OTP' : 'Reset Link'}</button>
                  ) : resetPwMethod === 'otp' && !resetPwVerified ? (
                    <>
                      <input type="text" value={resetPwOtpInput} onChange={e => setResetPwOtpInput(e.target.value)} placeholder="Enter OTP" style={{ width: '100%', marginBottom: 12, padding: 8, borderRadius: 8, border: '1.5px solid #bfc2d9' }} required />
                      <button type="button" style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer' }} onClick={() => {
                        if (resetPwOtpInput === resetPwOtp) { setResetPwVerified(true); } else { /* handle invalid OTP */ }
                      }}>Verify OTP</button>
                    </>
                  ) : (
                    <>
                      <div style={{ position: 'relative', marginBottom: 12 }}>
                        <input type={showPassword ? "text" : "password"} value={authPassword} onChange={e => setAuthPassword(e.target.value)} placeholder="New password" style={{ width: '100%', padding: 8, paddingRight: 40, borderRadius: 8, border: '1.5px solid #bfc2d9' }} required />
                        <button type="button" style={{ position: 'absolute', right: 10, top: 10, background: 'none', border: 'none', color: '#2563eb', fontWeight: 600, cursor: 'pointer', fontSize: 12 }} onClick={() => setShowPassword(v => !v)}>{showPassword ? 'Hide' : 'Show'}</button>
                      </div>
                      <button type="button" style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '10px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer' }} onClick={() => {
                        // ...existing code...
                        setResetPwMode(false); setAuthModalOpen(false);
                        setResetPwOtpSent(false); setResetPwVerified(false); setResetPwOtpInput('');
                      }}>Reset Password</button>
                    </>
                  )}
                </>
              ) : (
                <>
                  {authMode === 'signup' && (
                    <>
                      <div style={{ marginBottom: 8 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>First Name</label>
                        <input type="text" value={authFirstName} readOnly style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box', backgroundColor: '#f3f4f6', color: '#666', cursor: 'not-allowed' }} />
                      </div>
                      <div style={{ marginBottom: 8 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Last Name</label>
                        <input type="text" value={authLastName} readOnly style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box', backgroundColor: '#f3f4f6', color: '#666', cursor: 'not-allowed' }} />
                      </div>
                      <div style={{ marginBottom: 8 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Country</label>
                        <select value={authCountry} onChange={e => {
                          setAuthCountry(e.target.value);
                          const selectedCountry = COUNTRIES.find(c => c.name === e.target.value);
                          if (selectedCountry && !authPhone.startsWith(selectedCountry.phoneCode)) {
                            setAuthPhone(selectedCountry.phoneCode + ' ');
                          }
                        }} style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box', background: '#fff', cursor: 'pointer' }} required>
                          <option value="" disabled>Select your country</option>
                          {COUNTRIES.map(country => (
                            <option key={country.code} value={country.name}>{country.flag} {country.name}</option>
                          ))}
                        </select>
                      </div>
                      <div style={{ marginBottom: 8 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Phone Number</label>
                        <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                          {authCountry && (
                            <span style={{ fontSize: 20, minWidth: 30, textAlign: 'center' }}>
                              {COUNTRIES.find(c => c.name === authCountry)?.flag}
                            </span>
                          )}
                          <input type="tel" value={authPhone} onChange={e => setAuthPhone(e.target.value.replace(/[^\d+\-() ]/g, ''))} placeholder="Enter your number" style={{ flex: 1, padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} />
                        </div>
                      </div>
                      <div style={{ marginBottom: 8 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Address Line</label>
                        <input type="text" value={authAddressLine} onChange={e => setAuthAddressLine(e.target.value)} placeholder="e.g., 123 Main Street, Apt 4B" style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} />
                      </div>
                      <div style={{ marginBottom: 8 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>City/Town</label>
                        <input type="text" value={authCity} onChange={e => setAuthCity(e.target.value)} placeholder="e.g., Lagos" style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                      </div>
                      <div style={{ marginBottom: 12 }}>
                        <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Zip/Postcode</label>
                        <input type="text" value={authPostcode} onChange={e => setAuthPostcode(e.target.value)} placeholder="e.g., 10001" style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                      </div>
                    </>
                  )}
                  <div style={{ marginBottom: 8 }}>
                    <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Email</label>
                    <input type="email" value={authEmail} onChange={e => setAuthEmail(e.target.value)} placeholder="your@email.com" style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                  </div>
                  <div style={{ marginBottom: 12, position: 'relative' }}>
                    <label style={{ fontSize: 12, color: '#666', display: 'block', marginBottom: 4, fontWeight: 500 }}>Password</label>
                    <input type={showPassword ? "text" : "password"} value={authPassword} onChange={e => setAuthPassword(e.target.value)} placeholder="Secure password" style={{ width: '100%', padding: 10, borderRadius: 8, border: '1.5px solid #bfc2d9', fontSize: 14, boxSizing: 'border-box' }} required />
                    <button type="button" style={{ position: 'absolute', right: 12, top: 28, background: 'none', border: 'none', color: '#2563eb', fontWeight: 600, cursor: 'pointer', fontSize: 13 }} onClick={() => setShowPassword(v => !v)}>{showPassword ? 'Hide' : 'Show'}</button>
                  </div>
                  <button 
                    type="submit" 
                    style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '12px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer', transition: 'transform 0.3s ease' }}
                    onMouseEnter={(e) => {
                      e.currentTarget.style.transform = 'scale(1.05)';
                      e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
                    }}
                    onMouseLeave={(e) => {
                      e.currentTarget.style.transform = 'scale(1)';
                      e.currentTarget.style.boxShadow = 'none';
                    }}
                  >
                    {authMode === 'login' ? 'Login' : 'Sign Up'}
                  </button>
                  <button type="button" style={{ color: '#2563eb', fontWeight: 600, fontSize: 14, display: 'block', marginTop: 8, background: 'none', border: 'none', padding: 0, textAlign: 'left', cursor: 'pointer' }} onClick={() => setResetPwMode(true)}>Forgot password?</button>
                </>
              )}
            </form>
            <div style={{ textAlign: 'center', marginTop: 8 }}>
              {resetPwMode ? (
                <span>Remembered your password? <button type="button" style={{ color: '#2563eb', fontWeight: 600, background: 'none', border: 'none', padding: 0, cursor: 'pointer' }} onClick={() => setResetPwMode(false)}>Back to Login</button></span>
              ) : authMode === 'login' ? (
                <>
                  <span>Don't have an account? <button type="button" style={{ color: '#2563eb', fontWeight: 600, background: 'none', border: 'none', padding: 0, cursor: 'pointer' }} onClick={() => setAuthMode('signup')}>Sign Up</button></span><br />
                  <button type="button" style={{ color: '#2563eb', fontWeight: 600, fontSize: 14, background: 'none', border: 'none', padding: 0, textAlign: 'left', cursor: 'pointer' }} onClick={() => setResetPwMode(true)}>Forgot password?</button>
                </>
              ) : (
                <span>Already have an account? <button type="button" style={{ color: '#2563eb', fontWeight: 600, background: 'none', border: 'none', padding: 0, cursor: 'pointer' }} onClick={() => setAuthMode('login')}>Login</button></span>
              )}
            </div>
          </div>
        </div>
      )}

      {/* Email Verification Modal */}
      {showVerificationModal && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 2001, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 400, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => { setShowVerificationModal(false); setVerificationCode(''); }} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 12 }}>Verify Your Email</h3>
            <p style={{ color: '#666', marginBottom: 16 }}>We sent a 6-digit confirmation code to:</p>
            <p style={{ fontWeight: 600, marginBottom: 16, color: '#333' }}>{pendingVerificationEmail}</p>
            
            <form onSubmit={handleVerifyEmail}>
              <input
                type="text"
                value={verificationCode}
                onChange={e => setVerificationCode(e.target.value.replace(/\D/g, '').slice(0, 6))}
                placeholder="000000"
                maxLength="6"
                style={{ width: '100%', marginBottom: 12, padding: 12, fontSize: 18, borderRadius: 8, border: '1.5px solid #bfc2d9', textAlign: 'center', letterSpacing: 4, fontWeight: 600 }}
                required
              />
              {verificationError && <p style={{ color: '#dc2626', fontSize: 13, marginBottom: 12 }}>{verificationError}</p>}
              <button
                type="submit"
                style={{ background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, padding: '12px 0', fontWeight: 600, fontSize: 16, width: '100%', marginBottom: 8, cursor: 'pointer', transition: 'transform 0.3s ease' }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.transform = 'scale(1.05)';
                  e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.transform = 'scale(1)';
                  e.currentTarget.style.boxShadow = 'none';
                }}
              >
                Verify Code
              </button>
              <button
                type="button"
                style={{ color: '#2563eb', fontWeight: 600, fontSize: 14, background: 'none', border: 'none', padding: 0, cursor: 'pointer', width: '100%', textAlign: 'center' }}
                onClick={handleResendVerificationCode}
              >
                Didn't receive code? Resend
              </button>
            </form>
            <p style={{ color: '#999', fontSize: 12, marginTop: 16, textAlign: 'center' }}>Code expires in 10 minutes</p>
          </div>
        </div>
      )}

      {/* Main Card */}
      <main style={{ maxWidth: 900, margin: "32px auto 0 auto", background: "#fff", borderRadius: 18, boxShadow: "0 2px 12px #0002", padding: 36, border: "1.5px solid #ececec" }}>
        
        {/* Authentication Gate - Show if user is NOT logged in */}
        {!user ? (
          <div style={{ textAlign: 'center', padding: '40px 20px' }}>
            <div style={{ fontSize: 56, marginBottom: 20 }}>🔒</div>
            <h2 style={{ fontWeight: 700, fontSize: 26, marginBottom: 12, color: '#1f2937' }}>Sign In to Create Errands</h2>
            <p style={{ fontSize: 16, color: '#6b7280', marginBottom: 8, lineHeight: 1.6 }}>
              Only registered customers can create and manage errands on ErrandBridge.
            </p>
            <p style={{ fontSize: 14, color: '#9ca3af', marginBottom: 28 }}>
              Sign up to get started or login if you already have an account.
            </p>
            
            <div style={{ display: 'flex', gap: 12, justifyContent: 'center', marginBottom: 20 }}>
              <button
                onClick={() => { setAuthMode('signup'); setAuthModalOpen(true); }}
                style={{
                  background: '#2563eb',
                  color: '#fff',
                  border: 'none',
                  borderRadius: 10,
                  padding: '14px 32px',
                  fontSize: 16,
                  fontWeight: 600,
                  cursor: 'pointer',
                  transition: 'all 0.3s ease'
                }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.background = '#1d4ed8';
                  e.currentTarget.style.transform = 'translateY(-2px)';
                  e.currentTarget.style.boxShadow = '0 4px 12px rgba(37, 99, 235, 0.3)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.background = '#2563eb';
                  e.currentTarget.style.transform = 'translateY(0)';
                  e.currentTarget.style.boxShadow = 'none';
                }}
              >
                ✨ Sign Up
              </button>
              <button
                onClick={() => { setAuthMode('login'); setAuthModalOpen(true); }}
                style={{
                  background: '#f3f4f6',
                  color: '#2563eb',
                  border: '2px solid #2563eb',
                  borderRadius: 10,
                  padding: '14px 32px',
                  fontSize: 16,
                  fontWeight: 600,
                  cursor: 'pointer',
                  transition: 'all 0.3s ease'
                }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.background = '#dbeafe';
                  e.currentTarget.style.transform = 'translateY(-2px)';
                  e.currentTarget.style.boxShadow = '0 4px 12px rgba(37, 99, 235, 0.2)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.background = '#f3f4f6';
                  e.currentTarget.style.transform = 'translateY(0)';
                  e.currentTarget.style.boxShadow = 'none';
                }}
              >
                🔑 Login
              </button>
            </div>

            {/* Benefits/Why Join Section */}
            <div style={{ 
              background: '#f0f9ff', 
              border: '1px solid #bfdbfe', 
              borderRadius: 12, 
              padding: 20, 
              marginTop: 32,
              textAlign: 'left'
            }}>
              <h3 style={{ fontSize: 16, fontWeight: 600, color: '#0c4a6e', marginBottom: 12 }}>Why Join ErrandBridge?</h3>
              <ul style={{ margin: 0, paddingLeft: 20, color: '#1f2937', fontSize: 14, lineHeight: 1.8 }}>
                <li style={{ marginBottom: 8 }}>✅ Securely send items from EU/US to Lagos</li>
                <li style={{ marginBottom: 8 }}>✅ Real-time tracking and proof of delivery</li>
                <li style={{ marginBottom: 8 }}>✅ Verified service providers</li>
                <li style={{ marginBottom: 8 }}>✅ Encrypted file storage for sensitive documents</li>
                <li>✅ Dedicated customer support 24/7</li>
              </ul>
            </div>
          </div>
        ) : (
          <>
            {/* Route & Features Buttons - Above Create Errand */}
            <div style={{ marginBottom: 24 }}>
              <div style={{ display: "flex", gap: 12, marginBottom: 16, flexWrap: "nowrap", overflowX: "auto", paddingBottom: 8 }}>
                {[
                  "EU/US → Lagos (focus)",
                  "Proof-first delivery",
                  "Data minimisation by default",
                  "Assisted resolution if an issue occurs",
                  "No hidden fees"
                ].map((label, idx) => (
                  <button
                    key={label}
                    style={{
                      background: "#2563eb",
                      color: "#fff",
                      border: "none",
                      borderRadius: 12,
                      padding: "10px 16px",
                      fontWeight: 600,
                      fontSize: "14px",
                      cursor: "pointer",
                      boxShadow: '0 2px 6px rgba(37, 99, 235, 0.2)',
                      transition: 'all 0.2s ease',
                      textDecoration: "none",
                      whiteSpace: 'nowrap',
                      flexShrink: 0
                    }}
                    onClick={() => handleToggleInfo(idx)}
                    onMouseEnter={(e) => {
                      e.currentTarget.style.background = '#1d4ed8';
                      e.currentTarget.style.transform = 'translateY(-2px)';
                      e.currentTarget.style.boxShadow = '0 4px 12px rgba(37, 99, 235, 0.3)';
                    }}
                    onMouseLeave={(e) => {
                      e.currentTarget.style.background = '#2563eb';
                      e.currentTarget.style.transform = 'translateY(0)';
                      e.currentTarget.style.boxShadow = '0 2px 6px rgba(37, 99, 235, 0.2)';
                    }}
                  >
                    {label}
                  </button>
                ))}
              </div>
              <div style={{ color: "#666", fontSize: 14, lineHeight: 1.6, backgroundColor: '#f9fafb', padding: 12, borderRadius: 8, border: '1px solid #e5e7eb' }}>
                <strong style={{ color: '#1f2937' }}>Privacy notice (EU/UK/US):</strong> We apply data minimisation and purpose limitation. You can request deletion. Attachments are access-controlled and used solely to fulfil your errand.
              </div>
            </div>

            {/* Form Content - Only show if user IS logged in */}
            <h2 style={{ fontWeight: 700, fontSize: 22, marginBottom: 8 }}>Create a Diaspora Errand</h2>
            <div style={{ color: "#444", marginBottom: 16 }}>Choose a template, edit the details, and submit with proof expectations.</div>
        {/* Title */}
        <div style={{ marginBottom: 12 }}>
          <label style={{ fontWeight: 600 }}>Title</label>
          <div style={{ display: "flex", gap: 8, alignItems: "flex-start", marginTop: 4 }}>
            <div style={{ flex: 1, position: "relative" }}>
              <input 
                type="text" 
                value={title} 
                onChange={e => setTitle(e.target.value)} 
                placeholder="Title" 
                style={{ 
                  width: "100%", 
                  padding: 10, 
                  fontSize: 16, 
                  borderRadius: 8, 
                  border: "1.5px solid #bfc2d9" 
                }} 
              />
              
              {/* Title suggestions dropdown */}
              {showTitleSuggestions && titleSuggestions.length > 0 && (
                <div style={{
                  position: "absolute",
                  top: "100%",
                  left: 0,
                  right: 0,
                  background: "#fff",
                  border: "1.5px solid #2563eb",
                  borderRadius: "8px",
                  marginTop: 4,
                  boxShadow: "0 8px 16px rgba(37, 99, 235, 0.15)",
                  zIndex: 100,
                  maxHeight: "280px",
                  overflowY: "auto"
                }}>
                  <div style={{ padding: "8px 4px" }}>
                    <div style={{ fontSize: 12, fontWeight: 600, color: "#666", padding: "8px 12px", borderBottom: "1px solid #e5e7eb" }}>
                      ✨ AI Suggestions ({titleSuggestions.length})
                    </div>
                    {titleSuggestions.map((suggestion, idx) => (
                      <button
                        key={idx}
                        onClick={() => {
                          setTitle(suggestion);
                          setShowTitleSuggestions(false);
                        }}
                        style={{
                          display: "block",
                          width: "100%",
                          padding: "12px",
                          textAlign: "left",
                          background: "#fff",
                          border: "none",
                          borderBottom: idx < titleSuggestions.length - 1 ? "1px solid #f3f4f6" : "none",
                          cursor: "pointer",
                          fontSize: 14,
                          transition: "all 0.2s ease",
                          color: "#333"
                        }}
                        onMouseEnter={(e) => {
                          e.currentTarget.style.background = "#f0f9ff";
                          e.currentTarget.style.color = "#2563eb";
                          e.currentTarget.style.paddingLeft = "16px";
                        }}
                        onMouseLeave={(e) => {
                          e.currentTarget.style.background = "#fff";
                          e.currentTarget.style.color = "#333";
                          e.currentTarget.style.paddingLeft = "12px";
                        }}
                      >
                        {suggestion}
                      </button>
                    ))}
                  </div>
                </div>
              )}
            </div>
            
            {/* AI Title button */}
            <button 
              style={{ 
                background: titleLoading ? "#9ca3af" : "#2563eb", 
                color: "#fff", 
                border: "none", 
                borderRadius: 8, 
                padding: "10px 12px", 
                fontWeight: 600, 
                cursor: titleLoading ? "not-allowed" : "pointer",
                display: "flex",
                alignItems: "center",
                gap: "6px",
                transition: 'transform 0.3s ease',
                marginTop: 0,
                whiteSpace: "nowrap",
                fontSize: 14
              }} 
              onClick={handleAITitleSuggest}
              disabled={titleLoading}
              onMouseEnter={(e) => {
                if (!titleLoading) {
                  e.currentTarget.style.transform = 'scale(1.05)';
                  e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
                }
              }}
              onMouseLeave={(e) => {
                if (!titleLoading) {
                  e.currentTarget.style.transform = 'scale(1)';
                  e.currentTarget.style.boxShadow = 'none';
                }
              }}
              title="Generate AI-powered title suggestions based on your description"
            >
              <span style={{ fontSize: 16 }}>✨</span>
              {titleLoading ? "..." : "Title"}
            </button>
          </div>
          <div style={{ color: "#888", fontSize: 13, marginTop: 2 }}>Keep it short and specific (e.g., "Pick up passport from Ikeja office"). Click ✨ Title for AI suggestions!</div>
        </div>

        {/* Template */}
        <div style={{ marginBottom: 12 }}>
          <label style={{ fontWeight: 600 }}>Template:</label>
          <select value={template} onChange={handleTemplateChange} style={{ marginLeft: 8, padding: 6, borderRadius: 8, border: "1.5px solid #bfc2d9" }}>
            <option>Official Document / Office Pickup</option>
            <option>Bank Transaction</option>
            <option>Medical / Pharmacy Pickup</option>
            <option>Government Office / Immigration</option>
            <option>Hotel / Hospitality</option>
            <option>International Parcel</option>
            <option>Legal / Notary</option>
            <option>Corporate Logistics</option>
            <option>Personal Delivery</option>
            <option>Other</option>
          </select>
          <button 
            style={{ marginLeft: 8, padding: "6px 12px", borderRadius: 8, border: "1.5px solid #bfc2d9", background: "#fff", fontWeight: 600, cursor: "pointer", transition: 'transform 0.3s ease' }} 
            onClick={handleResetTemplate}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = 'none';
            }}
          >
            Reset template
          </button>
          <button 
            style={{ marginLeft: 8, padding: "6px 12px", borderRadius: 8, border: "1.5px solid #bfc2d9", background: "#fff", fontWeight: 600, cursor: "pointer", transition: 'transform 0.3s ease' }} 
            onClick={handleClearTemplate}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = 'none';
            }}
          >
            Clear
          </button>
          <button 
            style={{ marginLeft: 8, background: "#2563eb", color: "#fff", border: "none", borderRadius: 8, padding: "6px 12px", fontWeight: 600, cursor: "pointer", transition: 'transform 0.3s ease' }} 
            onClick={handleUseSuggestion}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = 'none';
            }}
          >
            Use suggestion
          </button>
          <button 
            style={{ 
              marginLeft: 8, 
              background: aiLoading ? "#9ca3af" : "#10b981", 
              color: "#fff", 
              border: "none", 
              borderRadius: 8, 
              padding: "6px 12px", 
              fontWeight: 600, 
              cursor: aiLoading ? "not-allowed" : "pointer",
              display: "flex",
              alignItems: "center",
              gap: "6px",
              transition: 'transform 0.3s ease'
            }} 
            onClick={handleAISuggest}
            disabled={aiLoading}
            onMouseEnter={(e) => {
              if (!aiLoading) {
                e.currentTarget.style.transform = 'scale(1.05)';
                e.currentTarget.style.boxShadow = '0 2px 8px rgba(16, 185, 129, 0.2)';
              }
            }}
            onMouseLeave={(e) => {
              if (!aiLoading) {
                e.currentTarget.style.transform = 'scale(1)';
                e.currentTarget.style.boxShadow = 'none';
              }
            }}
          >
            <span style={{ fontSize: 16 }}>✨</span> {aiLoading ? "Generating..." : "AI Enhance"}
          </button>
        </div>

        {/* Note */}
        <div style={{ marginBottom: 12 }}>
          <textarea value={note} onChange={e => setNote(e.target.value)} placeholder={"Write your errand note here.\nTip: start from the template and add:\n• Office/vendor name\n• Reference number\n• Pickup window\n• Who to call on delivery"} style={{ width: "100%", minHeight: 80, padding: 10, fontSize: 16, borderRadius: 8, border: "1.5px solid #bfc2d9" }} />
          {aiError && (
            <div style={{ color: "#dc2626", fontSize: 13, marginTop: 6, padding: 6, background: "#fee2e2", borderRadius: 6 }}>
              ⚠️ {aiError}
            </div>
          )}
          <div style={{ color: "#888", fontSize: 13, marginTop: 2 }}>Option B uses the backend suggest endpoint when available. It falls back to a local draft if needed.<br />What success looks like: clear contacts + landmark + pickup window, then proof (photo/receipt/scan) and a delivery call/message.</div>
        </div>

        {/* Sensitivity */}
        <div style={{ marginBottom: 12 }}>
          <label style={{ fontWeight: 600 }}>Sensitivity level (optional)</label>
          <select value={sensitivity} onChange={e => setSensitivity(e.target.value)} style={{ marginLeft: 8, padding: 6, borderRadius: 8, border: "1.5px solid #bfc2d9" }}>
            <option>Sensitive (documents, money, medicine)</option>
            <option>Normal</option>
            <option>Fragile (electronics, glass, etc.)</option>
            <option>Perishable (food, flowers, etc.)</option>
            <option>Confidential (legal, personal, etc.)</option>
            <option>Bulk/Heavy</option>
            <option>Other</option>
          </select>
          <div style={{ color: "#888", fontSize: 13, marginTop: 2 }}>This helps later with verified local runner selection, dispute handling, and pricing tiers.</div>
        </div>

        {/* Locations */}
        <div style={{ display: "flex", gap: 16, marginBottom: 12 }}>
          <div style={{ flex: 1, position: "relative" }}>
            <label style={{ fontWeight: 600 }}>Pickup Location 📍</label>
            <input 
              type="text" 
              value={pickup} 
              onChange={e => handlePickupInput(e.target.value)}
              onFocus={() => pickup.length > 1 && setShowPickupSuggestions(pickupSuggestions.length > 0)}
              placeholder="e.g., Lagos, Nigeria" 
              style={{ 
                width: "100%", 
                marginTop: 4, 
                padding: 10, 
                fontSize: 16, 
                borderRadius: 8, 
                border: "1.5px solid #bfc2d9",
                position: "relative",
                zIndex: 10
              }} 
            />
            {/* Pickup location suggestions */}
            {showPickupSuggestions && pickupSuggestions.length > 0 && (
              <div style={{
                position: "absolute",
                top: "100%",
                left: 0,
                right: 0,
                background: "#fff",
                border: "1.5px solid #667eea",
                borderRadius: "8px",
                marginTop: 2,
                boxShadow: "0 8px 16px rgba(102, 126, 234, 0.15)",
                zIndex: 100,
                maxHeight: "200px",
                overflowY: "auto"
              }}>
                {pickupSuggestions.map((suggestion, idx) => (
                  <button
                    key={idx}
                    onClick={() => selectPickupLocation(suggestion)}
                    style={{
                      display: "block",
                      width: "100%",
                      padding: "12px",
                      textAlign: "left",
                      background: "#fff",
                      border: "none",
                      borderBottom: idx < pickupSuggestions.length - 1 ? "1px solid #f3f4f6" : "none",
                      cursor: "pointer",
                      fontSize: 14,
                      transition: "all 0.2s ease",
                      color: "#333"
                    }}
                    onMouseEnter={(e) => {
                      e.currentTarget.style.background = "#f0f4ff";
                      e.currentTarget.style.color = "#667eea";
                      e.currentTarget.style.paddingLeft = "16px";
                    }}
                    onMouseLeave={(e) => {
                      e.currentTarget.style.background = "#fff";
                      e.currentTarget.style.color = "#333";
                      e.currentTarget.style.paddingLeft = "12px";
                    }}
                  >
                    📍 {suggestion}
                  </button>
                ))}
              </div>
            )}
          </div>
          <div style={{ flex: 1, position: "relative" }}>
            <label style={{ fontWeight: 600 }}>Dropoff Location 🎯</label>
            <input 
              type="text" 
              value={dropoff} 
              onChange={e => handleDropoffInput(e.target.value)}
              onFocus={() => dropoff.length > 1 && setShowDropoffSuggestions(dropoffSuggestions.length > 0)}
              placeholder="e.g., Abuja, Nigeria" 
              style={{ 
                width: "100%", 
                marginTop: 4, 
                padding: 10, 
                fontSize: 16, 
                borderRadius: 8, 
                border: "1.5px solid #bfc2d9",
                position: "relative",
                zIndex: 10
              }} 
            />
            {/* Dropoff location suggestions */}
            {showDropoffSuggestions && dropoffSuggestions.length > 0 && (
              <div style={{
                position: "absolute",
                top: "100%",
                left: 0,
                right: 0,
                background: "#fff",
                border: "1.5px solid #667eea",
                borderRadius: "8px",
                marginTop: 2,
                boxShadow: "0 8px 16px rgba(102, 126, 234, 0.15)",
                zIndex: 100,
                maxHeight: "200px",
                overflowY: "auto"
              }}>
                {dropoffSuggestions.map((suggestion, idx) => (
                  <button
                    key={idx}
                    onClick={() => selectDropoffLocation(suggestion)}
                    style={{
                      display: "block",
                      width: "100%",
                      padding: "12px",
                      textAlign: "left",
                      background: "#fff",
                      border: "none",
                      borderBottom: idx < dropoffSuggestions.length - 1 ? "1px solid #f3f4f6" : "none",
                      cursor: "pointer",
                      fontSize: 14,
                      transition: "all 0.2s ease",
                      color: "#333"
                    }}
                    onMouseEnter={(e) => {
                      e.currentTarget.style.background = "#f0f4ff";
                      e.currentTarget.style.color = "#667eea";
                      e.currentTarget.style.paddingLeft = "16px";
                    }}
                    onMouseLeave={(e) => {
                      e.currentTarget.style.background = "#fff";
                      e.currentTarget.style.color = "#333";
                      e.currentTarget.style.paddingLeft = "12px";
                    }}
                  >
                    🎯 {suggestion}
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>

        {/* Attachments */}
        <div style={{ marginBottom: 12 }}>
          <label style={{ fontWeight: 600 }}>Attachments (images/docs)</label>
          <input type="file" multiple style={{ display: "block", marginTop: 4, marginBottom: 4 }} ref={el => window.uploadedFilesInput = el} />
          <div style={{ color: "#888", fontSize: 13 }}>No files selected</div>
          <div style={{ color: "#888", fontSize: 13, marginTop: 2 }}>Upload photos or documents only when required. Files are encrypted, access-restricted, and used solely for errand completion. Attachments are removed after the errand is closed.<br />Proof checklist: photo at pickup • receipt or document scan • message/call on delivery.<br />Post-submit: we create the errand first, then upload your files in the background (if upload fails, your errand is still saved).</div>

        {/* Contact Information Button */}
        <div style={{ marginTop: 16, marginBottom: 16 }}>
          <button
            type="button"
            onClick={() => setShowContactModal(true)}
            style={{
              background: "#f0f9ff",
              border: "1px solid #bfdbfe",
              borderRadius: 8,
              padding: "10px 16px",
              fontSize: 14,
              fontWeight: 600,
              color: "#0c4a6e",
              cursor: "pointer",
              display: "flex",
              alignItems: "center",
              gap: 8,
              transition: "background-color 0.2s ease"
            }}
            onMouseEnter={(e) => e.target.style.background = "#e0f2fe"}
            onMouseLeave={(e) => e.target.style.background = "#f0f9ff"}
          >
            <span>📞</span> Contact & Support
          </button>
        </div>

          <div style={{ margin: "16px 0", display: "flex", alignItems: "center", gap: 8 }}>
            <input type="checkbox" checked={agreed} onChange={e => setAgreed(e.target.checked)} style={{ width: 24, height: 24 }} />
            <span style={{ fontSize: 15 }}>I confirm I've read and agree to the <button type="button" onClick={() => setShowPolicyModal(true)} style={{ color: "#2563eb", fontWeight: 600, background: 'none', border: 'none', padding: 0, cursor: 'pointer', textDecoration: 'underline' }}>Terms-lite pilot policy</button>.</span>
          </div>
          <div style={{ color: "#888", fontSize: 13, marginBottom: 8 }}>Especially for sensitive errands: don’t upload documents unless necessary.</div>
        </div>

        {/* Submit Button */}
  <button
    style={{
      background: (!title || !agreed) ? "#8fa8f8" : "#2563eb",
      color: "#fff",
      border: "none",
      borderRadius: 8,
      padding: "12px 0",
      fontWeight: 700,
      fontSize: 18,
      width: 180,
      marginBottom: 18,
      cursor: (!title || !agreed) ? "not-allowed" : "pointer",
      boxShadow: (!title || !agreed) ? "none" : "0 2px 12px #2563eb44",
      transition: "background 0.2s, box-shadow 0.2s, transform 0.3s ease"
    }}
    disabled={!title || !agreed}
    onClick={handleSubmitErrand}
    onMouseEnter={(e) => {
      if (!(!title || !agreed)) {
        e.currentTarget.style.transform = 'scale(1.05)';
        e.currentTarget.style.boxShadow = '0 4px 16px rgba(37, 99, 235, 0.3)';
      }
    }}
    onMouseLeave={(e) => {
      if (!(!title || !agreed)) {
        e.currentTarget.style.transform = 'scale(1)';
        e.currentTarget.style.boxShadow = '0 2px 12px #2563eb44';
      }
    }}
  >
    Submit Errand
  </button>

        {/* Before you submit warning */}
        {!title && (
          <div style={{ background: "#eaf0fb", color: "#2563eb", borderRadius: 10, padding: 16, marginBottom: 18, fontWeight: 600, fontSize: 17 }}>
            Before you submit<br /><span style={{ fontWeight: 400, fontSize: 15 }}>Add a title to enable submit.</span>
          </div>
        )}

        {/* Transparency section */}
        <div style={{ background: "#fafbfc", borderRadius: 12, padding: 18, marginBottom: 18, border: "1.5px solid #ececec", display: "flex", flexDirection: "column", gap: 8 }}>
          <div style={{ fontWeight: 700, fontSize: 18 }}>Your Transparency</div>
          <div style={{ display: "flex", gap: 24, alignItems: "flex-start", flexWrap: "wrap" }}>
            {/* Completed Errands */}
            <div style={{ display: "flex", alignItems: "center", gap: 12, padding: 12, background: "#fff", borderRadius: 8, border: "1px solid #e0e0e0" }}>
              <div>
                <div style={{ fontWeight: 700, fontSize: 32, color: "#16a34a" }}>{errands.filter(e => e.status === 'completed').length}</div>
                <div style={{ color: "#666", fontSize: 12, whiteSpace: "nowrap" }}>Completed Errands</div>
              </div>
            </div>
            
            {/* Documents Handled */}
            <div style={{ display: "flex", alignItems: "center", gap: 12, padding: 12, background: "#fff", borderRadius: 8, border: "1px solid #e0e0e0" }}>
              <div>
                <div style={{ fontWeight: 700, fontSize: 32, color: "#2563eb" }}>{uploadedFiles.length}</div>
                <div style={{ color: "#666", fontSize: 12, whiteSpace: "nowrap" }}>Documents Uploaded</div>
              </div>
            </div>
            
            {/* View All Documents Button */}
            {uploadedFiles.length > 0 && (
              <button 
                style={{ marginLeft: "auto", border: "1.5px solid #2563eb", borderRadius: 8, padding: "8px 16px", background: "#fff", color: "#2563eb", fontWeight: 600, cursor: "pointer", transition: 'transform 0.3s ease' }} 
                onClick={() => setDetailsModal({ open: true, errand: null, transparency: true })}
                onMouseEnter={(e) => {
                  e.currentTarget.style.transform = 'scale(1.05)';
                  e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.transform = 'scale(1)';
                  e.currentTarget.style.boxShadow = 'none';
                }}
              >
                📁 View All Documents
              </button>
            )}
          </div>
          <div style={{ color: "#666", fontSize: 12, marginTop: 8 }}>
            ℹ️ Your transparency counts reflect all errands and document attachments in your account. These are used for verification and audit purposes.
          </div>
        </div>

        {/* Your Errands section */}
        <div style={{ background: "#fafbfc", borderRadius: 12, padding: 18, border: "1.5px solid #ececec", marginBottom: 8 }}>
          <div style={{ fontWeight: 700, fontSize: 20, marginBottom: errandsSectionMinimized ? 0 : 16, display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>
            <span>📋 Your Errands ({errands.length})</span>
            <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
              {selectedErrands.length > 0 && (
                <button 
                  style={{ background: '#dc2626', color: '#fff', border: 'none', borderRadius: 8, padding: '6px 12px', fontWeight: 600, cursor: 'pointer', fontSize: 14, transition: 'transform 0.3s ease' }} 
                  onClick={handleDeleteSelected}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.transform = 'scale(1.05)';
                    e.currentTarget.style.boxShadow = '0 2px 8px rgba(220, 38, 38, 0.2)';
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.transform = 'scale(1)';
                    e.currentTarget.style.boxShadow = 'none';
                  }}
                >
                  🗑️ Delete {selectedErrands.length} Selected
                </button>
              )}
              <button 
                onClick={() => setErrandsSectionMinimized(!errandsSectionMinimized)}
                style={{ 
                  background: '#e5e7eb', 
                  border: 'none', 
                  borderRadius: 6, 
                  padding: '4px 8px', 
                  cursor: 'pointer',
                  fontWeight: 600,
                  fontSize: 12,
                  color: '#374151',
                  transition: 'transform 0.3s ease'
                }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.transform = 'scale(1.05)';
                  e.currentTarget.style.boxShadow = '0 2px 8px rgba(0, 0, 0, 0.1)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.transform = 'scale(1)';
                  e.currentTarget.style.boxShadow = 'none';
                }}
              >
                {errandsSectionMinimized ? '📈 Expand' : '📉 Collapse'}
              </button>
            </div>
          </div>
          
          {!errandsSectionMinimized && (
            <>
          {errands.length === 0 ? (
            <div style={{ color: "#666", fontSize: 14, padding: 20, textAlign: 'center', background: '#fff', borderRadius: 8 }}>
              📭 No errands yet. Create one to get started!
            </div>
          ) : (
            <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
              {/* Select All Header */}
              <div style={{ display: 'flex', alignItems: 'center', gap: 12, padding: 12, background: '#f9fafb', borderRadius: 8, border: '1px solid #e5e7eb' }}>
                <input 
                  type="checkbox" 
                  checked={selectAll} 
                  onChange={handleSelectAll}
                  style={{ cursor: 'pointer', width: 18, height: 18 }}
                />
                <span style={{ fontWeight: 600, color: '#374151', fontSize: 14 }}>
                  Select All ({selectedErrands.length}/{errands.length})
                </span>
              </div>
              
              {errands.map(e => {
                const isExpanded = expandedErrandId === e.id;
                const statusBadge = getStatusBadge(e.status);
                return (
                  <div key={e.id} style={{ border: '1px solid #ddd', borderRadius: 8, overflow: 'hidden', background: '#fff' }}>
                    {/* Main Row - Clickable to expand */}
                    <div 
                      style={{
                        display: 'flex', 
                        alignItems: 'center', 
                        gap: 12, 
                        padding: 12, 
                        background: isExpanded ? '#f0f9ff' : '#fff',
                        cursor: 'pointer',
                        borderBottom: isExpanded ? '1px solid #ddd' : 'none',
                        transition: 'background 0.2s'
                      }}
                      onClick={() => setExpandedErrandId(isExpanded ? null : e.id)}
                    >
                      {/* Checkbox */}
                      <input 
                        type="checkbox" 
                        checked={selectedErrands.includes(e.id)} 
                        onChange={(evt) => {
                          evt.stopPropagation();
                          handleSelectErrand(e.id);
                        }}
                        style={{ cursor: 'pointer' }}
                      />
                      
                      {/* Expand/Collapse Icon */}
                      <div style={{ fontSize: 18, minWidth: 20 }}>{isExpanded ? '▼' : '▶'}</div>
                      
                      {/* Reference # */}
                      <div style={{ fontFamily: 'monospace', fontSize: 12, color: '#666', minWidth: 100 }}>
                        {e.referenceNumber}
                      </div>
                      
                      {/* Title */}
                      <div style={{ fontWeight: 600, flex: 1, minWidth: 150 }}>
                        {e.title}
                      </div>
                      
                      {/* Status Badge */}
                      <div style={{
                        background: statusBadge.bg,
                        color: statusBadge.color,
                        padding: '4px 10px',
                        borderRadius: 6,
                        fontSize: 12,
                        fontWeight: 600,
                        whiteSpace: 'nowrap',
                        minWidth: 110,
                        textAlign: 'center'
                      }}>
                        {statusBadge.icon} {e.status.charAt(0).toUpperCase() + e.status.slice(1)}
                      </div>
                      
                      {/* Created Date */}
                      <div style={{ fontSize: 12, color: '#666', minWidth: 140, textAlign: 'right' }}>
                        {e.createdAt ? new Date(e.createdAt).toLocaleDateString() : ''}
                      </div>
                      
                      {/* Action Buttons */}
                      {/* Show Assign button for admin when status is submitted */}
                      {userIsAdmin && e.status === 'submitted' && (
                        <button 
                          onClick={(evt) => {
                            evt.stopPropagation();
                            handleAssignErrand(e.id);
                          }}
                          style={{ 
                            background: '#8b5cf6', 
                            color: '#fff', 
                            border: 'none', 
                            borderRadius: 6, 
                            padding: '4px 10px', 
                            fontWeight: 600, 
                            cursor: 'pointer',
                            fontSize: 12,
                            transition: 'transform 0.3s ease',
                            marginRight: 8
                          }}
                          title="Assign this errand to yourself"
                          onMouseEnter={(e) => {
                            e.currentTarget.style.transform = 'scale(1.05)';
                            e.currentTarget.style.boxShadow = '0 2px 8px rgba(139, 92, 246, 0.2)';
                          }}
                          onMouseLeave={(e) => {
                            e.currentTarget.style.transform = 'scale(1)';
                            e.currentTarget.style.boxShadow = 'none';
                          }}
                        >
                          👤 Assign
                        </button>
                      )}
                      
                      {/* Show Done button for admin/customer when status is assigned */}
                      {e.status === 'assigned' && (userIsAdmin || e.userId === parseInt(localStorage.getItem('userId'))) && (
                        <button 
                          onClick={(evt) => {
                            evt.stopPropagation();
                            handleMarkDone(e.id);
                          }}
                          style={{ 
                            background: '#10b981', 
                            color: '#fff', 
                            border: 'none', 
                            borderRadius: 6, 
                            padding: '4px 10px', 
                            fontWeight: 600, 
                            cursor: 'pointer',
                            fontSize: 12,
                            transition: 'transform 0.3s ease',
                            marginRight: 8
                          }}
                          title="Mark this errand as complete"
                          onMouseEnter={(e) => {
                            e.currentTarget.style.transform = 'scale(1.05)';
                            e.currentTarget.style.boxShadow = '0 2px 8px rgba(16, 185, 129, 0.2)';
                          }}
                          onMouseLeave={(e) => {
                            e.currentTarget.style.transform = 'scale(1)';
                            e.currentTarget.style.boxShadow = 'none';
                          }}
                        >
                          ✅ Done
                        </button>
                      )}
                      
                      <button 
                        onClick={(evt) => {
                          evt.stopPropagation();
                          handleEditErrand(e);
                        }}
                        style={{ 
                          background: '#2563eb', 
                          color: '#fff', 
                          border: 'none', 
                          borderRadius: 6, 
                          padding: '4px 10px', 
                          fontWeight: 600, 
                          cursor: 'pointer',
                          fontSize: 12,
                          transition: 'transform 0.3s ease',
                          marginRight: 8
                        }}
                        onMouseEnter={(e) => {
                          e.currentTarget.style.transform = 'scale(1.05)';
                          e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
                        }}
                        onMouseLeave={(e) => {
                          e.currentTarget.style.transform = 'scale(1)';
                          e.currentTarget.style.boxShadow = 'none';
                        }}
                      >
                        ✏️ Edit
                      </button>
                      <button 
                        onClick={(evt) => {
                          evt.stopPropagation();
                          handleDeleteErrand(e.id);
                        }}
                        style={{ 
                          background: '#dc2626', 
                          color: '#fff', 
                          border: 'none', 
                          borderRadius: 6, 
                          padding: '4px 10px', 
                          fontWeight: 600, 
                          cursor: 'pointer',
                          fontSize: 12,
                          transition: 'transform 0.3s ease'
                        }}
                        onMouseEnter={(e) => {
                          e.currentTarget.style.transform = 'scale(1.05)';
                          e.currentTarget.style.boxShadow = '0 2px 8px rgba(220, 38, 38, 0.2)';
                        }}
                        onMouseLeave={(e) => {
                          e.currentTarget.style.transform = 'scale(1)';
                          e.currentTarget.style.boxShadow = 'none';
                        }}
                      >
                        Delete
                      </button>
                    </div>
                    
                    {/* Expanded Details Section */}
                    {isExpanded && (
                      <div style={{ padding: 16, background: 'linear-gradient(135deg, #f5f7fa 0%, #fafbfc 100%)', borderTop: '1px solid #e5e7eb' }}>
                        {/* Assignment Status */}
                        {e.assignedTo && (
                          <div style={{ background: '#fef3c7', padding: 12, borderRadius: 10, marginBottom: 16, border: '1px solid #fcd34d' }}>
                            <div style={{ fontWeight: 700, color: '#92400e', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                              <span>👤</span>
                              <span>Assignment Status</span>
                            </div>
                            <div style={{ color: '#78350f', fontSize: 12 }}>
                              Assigned to Admin (ID: {e.assignedTo})
                              {e.assignedAt && ` on ${new Date(e.assignedAt).toLocaleDateString()}`}
                            </div>
                          </div>
                        )}
                        
                        {/* Review Status */}
                        {e.reviewStatus && (
                          <div style={{ 
                            background: e.reviewStatus === 'reviewed' ? '#d1fae5' : '#f3e8ff',
                            padding: 12,
                            borderRadius: 10,
                            marginBottom: 16,
                            border: `1px solid ${e.reviewStatus === 'reviewed' ? '#a7f3d0' : '#e9d5ff'}`
                          }}>
                            <div style={{ fontWeight: 700, color: e.reviewStatus === 'reviewed' ? '#065f46' : '#6b21a8', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                              <span>⭐</span>
                              <span>Customer Review</span>
                            </div>
                            {e.reviewStatus === 'reviewed' ? (
                              <div style={{ color: e.reviewStatus === 'reviewed' ? '#047857' : '#7e22ce', fontSize: 12 }}>
                                <div>Rating: {e.reviewerRating} / 5 ⭐</div>
                                {e.reviewerNotes && <div style={{ marginTop: 6 }}>{e.reviewerNotes}</div>}
                                {e.reviewCompletedAt && <div style={{ marginTop: 6, fontSize: 11, opacity: 0.8 }}>Reviewed on {new Date(e.reviewCompletedAt).toLocaleDateString()}</div>}
                              </div>
                            ) : (
                              <div style={{ color: '#7e22ce', fontSize: 12 }}>Pending customer review...</div>
                            )}
                          </div>
                        )}
                        
                        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 16, fontSize: 13, marginBottom: 16 }}>
                          <div style={{ background: '#fff', padding: 12, borderRadius: 10, boxShadow: '0 2px 8px rgba(0,0,0,0.05)' }}>
                            <div style={{ fontWeight: 700, color: '#2563eb', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                              <span>📍</span>
                              <span>Pickup Location</span>
                            </div>
                            <div style={{ color: '#333', lineHeight: '1.5', fontSize: 12 }}>{e.pickupLocation}</div>
                          </div>
                          <div style={{ background: '#fff', padding: 12, borderRadius: 10, boxShadow: '0 2px 8px rgba(0,0,0,0.05)' }}>
                            <div style={{ fontWeight: 700, color: '#2563eb', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                              <span>🎯</span>
                              <span>Dropoff Location</span>
                            </div>
                            <div style={{ color: '#333', lineHeight: '1.5', fontSize: 12 }}>{e.dropoffLocation}</div>
                          </div>
                          <div style={{ background: '#fff', padding: 12, borderRadius: 10, boxShadow: '0 2px 8px rgba(0,0,0,0.05)' }}>
                            <div style={{ fontWeight: 700, color: '#dc2626', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                              <span>⚠️</span>
                              <span>Sensitivity Level</span>
                            </div>
                            <div style={{ color: '#333', lineHeight: '1.5', fontSize: 12 }}>{e.sensitivity}</div>
                          </div>
                          <div style={{ background: '#fff', padding: 12, borderRadius: 10, boxShadow: '0 2px 8px rgba(0,0,0,0.05)' }}>
                            <div style={{ fontWeight: 700, color: '#10b981', marginBottom: 6, display: 'flex', alignItems: 'center', gap: 6 }}>
                              <span>📅</span>
                              <span>Created Date</span>
                            </div>
                            <div style={{ color: '#333', lineHeight: '1.5', fontSize: 12 }}>{e.createdAt ? new Date(e.createdAt).toLocaleString() : ''}</div>
                          </div>
                        </div>
                        
                        {/* Enhanced Notes with Flip Card */}
                        {e.note && (
                          <div style={{ marginTop: 16 }}>
                            <div style={{ 
                              perspective: '1000px',
                              position: 'relative',
                              minHeight: '140px'
                            }}>
                              <div 
                                style={{ 
                                  background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                                  borderRadius: 12,
                                  padding: 16,
                                  color: '#fff',
                                  cursor: 'pointer',
                                  transition: 'transform 0.3s ease, box-shadow 0.3s ease',
                                  boxShadow: '0 4px 15px rgba(102, 126, 234, 0.2)',
                                  position: 'relative'
                                }}
                                onMouseEnter={(e) => {
                                  e.currentTarget.style.transform = 'translateY(-4px) rotateX(5deg)';
                                  e.currentTarget.style.boxShadow = '0 8px 25px rgba(102, 126, 234, 0.35)';
                                }}
                                onMouseLeave={(e) => {
                                  e.currentTarget.style.transform = 'translateY(0) rotateX(0)';
                                  e.currentTarget.style.boxShadow = '0 4px 15px rgba(102, 126, 234, 0.2)';
                                }}
                              >
                                <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 10 }}>
                                  <span style={{ fontSize: 24 }}>📝</span>
                                  <span style={{ fontWeight: 700, fontSize: 16, letterSpacing: '0.5px' }}>Notes</span>
                                </div>
                                <div style={{ 
                                  whiteSpace: 'pre-wrap', 
                                  fontSize: 14, 
                                  lineHeight: '1.6',
                                  color: '#f0f4ff',
                                  fontWeight: 500
                                }}>
                                  {e.note}
                                </div>
                                <div style={{ 
                                  marginTop: 10, 
                                  fontSize: 12, 
                                  color: '#d4d8ff',
                                  display: 'flex',
                                  alignItems: 'center',
                                  gap: 4
                                }}>
                                  <span>✨</span>
                                  <span>Click to see more details</span>
                                </div>
                              </div>
                            </div>
                          </div>
                        )}
                        
                        {/* Enhanced Status Timeline */}
                        {e.history && e.history.length > 0 && (
                          <div style={{ marginTop: 16 }}>
                            <div style={{ fontWeight: 700, fontSize: 14, color: '#1f2937', marginBottom: 12, display: 'flex', alignItems: 'center', gap: 8 }}>
                              <span>⏱️</span>
                              <span>Activity Timeline</span>
                            </div>
                            <div style={{ 
                              borderLeft: '3px solid #667eea', 
                              paddingLeft: 16,
                              position: 'relative'
                            }}>
                              {e.history.map((h, idx) => {
                                const getStatusEmoji = (status) => {
                                  const emojiMap = {
                                    'submitted': '✅',
                                    'pending': '⏳',
                                    'in_progress': '🔄',
                                    'completed': '🎉',
                                    'failed': '❌',
                                    'cancelled': '🚫'
                                  };
                                  return emojiMap[status?.toLowerCase()] || '📌';
                                };
                                
                                return (
                                  <div key={idx} style={{ marginBottom: 14, position: 'relative' }}>
                                    <div style={{ 
                                      position: 'absolute',
                                      left: '-23px',
                                      top: '0px',
                                      width: '12px',
                                      height: '12px',
                                      background: '#667eea',
                                      borderRadius: '50%',
                                      border: '3px solid #fff'
                                    }} />
                                    <div style={{ background: '#fff', padding: 10, borderRadius: 8, boxShadow: '0 2px 6px rgba(0,0,0,0.05)', transition: 'all 0.3s ease' }}>
                                      <div style={{ fontWeight: 700, color: '#333', fontSize: 13, display: 'flex', alignItems: 'center', gap: 6 }}>
                                        <span>{getStatusEmoji(h.newStatus)}</span>
                                        <span>{h.eventType}</span>
                                        <span style={{ color: '#667eea', fontWeight: 700 }}>→</span>
                                        <span style={{ color: '#667eea' }}>{h.newStatus?.charAt(0).toUpperCase() + h.newStatus?.slice(1)}</span>
                                      </div>
                                      <div style={{ color: '#666', fontSize: 12, marginTop: 4 }}>
                                        🕐 {h.createdAt ? new Date(h.createdAt).toLocaleString() : ''}
                                      </div>
                                    </div>
                                  </div>
                                );
                              })}
                            </div>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          )}
            </>
          )}
        </div>
      {/* Details Modal for Errand or Transparency */}
      {detailsModal.open && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 3000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 500, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => setDetailsModal({ open: false, errand: null })} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            {detailsModal.transparency ? (
              <>
                <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 12 }}>All Uploaded Files</h3>
                {uploadedFiles.length === 0 ? <div>No files uploaded.</div> : (
                  <ul>
                    {uploadedFiles.map(f => (
                      <li key={f.id}><a href={f.url} target="_blank" rel="noopener noreferrer">{f.filename}</a></li>
                    ))}
                  </ul>
                )}
              </>
            ) : detailsModal.errand ? (
              <>
                <h3 style={{ fontWeight: 700, fontSize: 22, marginBottom: 12 }}>Errand Details</h3>
                <div><b>Reference:</b> {detailsModal.errand.referenceNumber}</div>
                <div><b>Title:</b> {detailsModal.errand.title}</div>
                <div><b>Status:</b> {detailsModal.errand.status}</div>
                <div><b>Pickup:</b> {detailsModal.errand.pickupLocation}</div>
                <div><b>Dropoff:</b> {detailsModal.errand.dropoffLocation}</div>
                <div><b>Sensitivity:</b> {detailsModal.errand.sensitivity}</div>
                <div><b>Created:</b> {detailsModal.errand.createdAt ? new Date(detailsModal.errand.createdAt).toLocaleString() : ''}</div>
                <div><b>Note:</b> <pre style={{ whiteSpace: 'pre-wrap', background: '#f7f7fa', padding: 8, borderRadius: 6 }}>{detailsModal.errand.note}</pre></div>
                {/* Errand History Timeline */}
                {detailsModal.errand.history && detailsModal.errand.history.length > 0 && (
                  <div style={{ marginTop: 18 }}>
                    <b>History:</b>
                    <ul style={{ margin: 0, paddingLeft: 18 }}>
                      {detailsModal.errand.history.map((h, idx) => (
                        <li key={idx} style={{ marginBottom: 6 }}>
                          <span style={{ fontWeight: 600 }}>{h.eventType.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}</span>
                          {h.oldStatus && h.newStatus && (
                            <span style={{ marginLeft: 6, color: '#888' }}>({h.oldStatus} → {h.newStatus})</span>
                          )}
                          <span style={{ marginLeft: 8, color: '#2563eb' }}>{h.createdAt ? new Date(h.createdAt).toLocaleString() : ''}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </>
            ) : null}
          </div>
        </div>
      )}
          </>
        )}
      </main>

      {/* Info Modal */}
      {infoOpen && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: 'rgba(0,0,0,0.32)', zIndex: 1100, display: 'flex', alignItems: 'center', justifyContent: 'center', transition: 'background 0.3s', animation: 'fadeInBg 0.3s' }}>
          <div style={{ background: '#fff', borderRadius: 22, padding: '38px 36px 32px 36px', minWidth: 340, maxWidth: 440, boxShadow: '0 8px 32px #0004', position: 'relative', animation: 'fadeInModal 0.35s' }}>
            <button onClick={() => setInfoOpen(false)}
              style={{ position: 'absolute', top: 18, right: 22, background: 'none', border: 'none', fontSize: 28, cursor: 'pointer', color: '#2563eb', fontWeight: 700, borderRadius: '50%', width: 38, height: 38, lineHeight: '38px', textAlign: 'center', transition: 'background 0.2s' }}
              onMouseOver={e => e.currentTarget.style.background = '#f3f4f6'}
              onMouseOut={e => e.currentTarget.style.background = 'none'}
              aria-label="Close info dialog"
            >&times;</button>
            <div style={{ fontWeight: 800, fontSize: 22, marginBottom: 16, color: '#2563eb', letterSpacing: 0.2 }}>Info</div>
            <div style={{ color: '#222', fontSize: 16, lineHeight: 1.6, whiteSpace: 'pre-line' }}>{infoContent}</div>
          </div>
          <style>{`
            @keyframes fadeInModal { from { opacity: 0; transform: translateY(30px) scale(0.98); } to { opacity: 1; transform: none; } }
            @keyframes fadeInBg { from { opacity: 0; } to { opacity: 1; } }
          `}</style>
        </div>
      )}

      {/* Edit Errand Modal */}
      {editModalOpen && editingErrand && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: 'rgba(0,0,0,0.32)', zIndex: 2000, display: 'flex', alignItems: 'center', justifyContent: 'center', overflow: 'auto' }}>
          <div style={{ background: '#fff', borderRadius: 22, padding: '38px 36px 32px 36px', minWidth: 340, maxWidth: 600, boxShadow: '0 8px 32px #0004', position: 'relative', margin: 20 }}>
            <button onClick={() => setEditModalOpen(false)}
              style={{ position: 'absolute', top: 18, right: 22, background: 'none', border: 'none', fontSize: 28, cursor: 'pointer', color: '#2563eb', fontWeight: 700, borderRadius: '50%', width: 38, height: 38, lineHeight: '38px', textAlign: 'center', transition: 'background 0.2s' }}
              onMouseOver={e => e.currentTarget.style.background = '#f3f4f6'}
              onMouseOut={e => e.currentTarget.style.background = 'none'}
              aria-label="Close edit dialog"
            >&times;</button>
            
            <div style={{ fontWeight: 800, fontSize: 22, marginBottom: 24, color: '#2563eb', display: 'flex', alignItems: 'center', gap: 8 }}>
              ✏️ Edit Errand
            </div>

            {/* Edit Form Fields */}
            <div style={{ display: 'grid', gridTemplateColumns: '1fr', gap: 16, marginBottom: 24 }}>
              
              {/* Title */}
              <div>
                <label style={{ fontWeight: 600, fontSize: 13, color: '#2563eb', marginBottom: 6, display: 'block' }}>📝 Title *</label>
                <input
                  type="text"
                  value={editFormData.title || ''}
                  onChange={(e) => setEditFormData({ ...editFormData, title: e.target.value })}
                  placeholder="Enter errand title"
                  style={{ width: '100%', padding: '10px 12px', border: '1.5px solid #bfc2d9', borderRadius: 8, fontSize: 14, fontFamily: 'inherit', boxSizing: 'border-box' }}
                />
              </div>

              {/* Note/Description */}
              <div>
                <label style={{ fontWeight: 600, fontSize: 13, color: '#2563eb', marginBottom: 6, display: 'block' }}>📋 Description</label>
                <textarea
                  value={editFormData.note || ''}
                  onChange={(e) => setEditFormData({ ...editFormData, note: e.target.value })}
                  placeholder="Enter errand details"
                  style={{ width: '100%', padding: '10px 12px', border: '1.5px solid #bfc2d9', borderRadius: 8, fontSize: 14, fontFamily: 'inherit', boxSizing: 'border-box', minHeight: 80, resize: 'none' }}
                />
              </div>

              {/* Pickup Location */}
              <div>
                <label style={{ fontWeight: 600, fontSize: 13, color: '#2563eb', marginBottom: 6, display: 'block' }}>📍 Pickup Location *</label>
                <input
                  type="text"
                  value={editFormData.pickupLocation || ''}
                  onChange={(e) => setEditFormData({ ...editFormData, pickupLocation: e.target.value })}
                  placeholder="Enter pickup location"
                  style={{ width: '100%', padding: '10px 12px', border: '1.5px solid #bfc2d9', borderRadius: 8, fontSize: 14, fontFamily: 'inherit', boxSizing: 'border-box' }}
                />
              </div>

              {/* Dropoff Location */}
              <div>
                <label style={{ fontWeight: 600, fontSize: 13, color: '#2563eb', marginBottom: 6, display: 'block' }}>🎯 Dropoff Location *</label>
                <input
                  type="text"
                  value={editFormData.dropoffLocation || ''}
                  onChange={(e) => setEditFormData({ ...editFormData, dropoffLocation: e.target.value })}
                  placeholder="Enter dropoff location"
                  style={{ width: '100%', padding: '10px 12px', border: '1.5px solid #bfc2d9', borderRadius: 8, fontSize: 14, fontFamily: 'inherit', boxSizing: 'border-box' }}
                />
              </div>

              {/* Template Selection */}
              <div>
                <label style={{ fontWeight: 600, fontSize: 13, color: '#2563eb', marginBottom: 6, display: 'block' }}>🏷️ Template</label>
                <select
                  value={editFormData.template || 'Official Document / Office Pickup'}
                  onChange={(e) => setEditFormData({ ...editFormData, template: e.target.value })}
                  style={{ width: '100%', padding: '10px 12px', border: '1.5px solid #bfc2d9', borderRadius: 8, fontSize: 14, fontFamily: 'inherit', boxSizing: 'border-box' }}
                >
                  <option>Official Document / Office Pickup</option>
                  <option>Grocery Delivery</option>
                  <option>Personal Item / Package Delivery</option>
                  <option>Laundry Delivery</option>
                  <option>Food Order Delivery</option>
                  <option>Bill Payment / Financial Transaction</option>
                  <option>Service Request</option>
                  <option>Meeting / Appointment Coordination</option>
                  <option>Medical / Prescription Delivery</option>
                  <option>Special Request</option>
                </select>
              </div>

              {/* Sensitivity */}
              <div>
                <label style={{ fontWeight: 600, fontSize: 13, color: '#2563eb', marginBottom: 6, display: 'block' }}>⚠️ Sensitivity</label>
                <select
                  value={editFormData.sensitivity || 'Sensitive (documents, money, medicine)'}
                  onChange={(e) => setEditFormData({ ...editFormData, sensitivity: e.target.value })}
                  style={{ width: '100%', padding: '10px 12px', border: '1.5px solid #bfc2d9', borderRadius: 8, fontSize: 14, fontFamily: 'inherit', boxSizing: 'border-box' }}
                >
                  <option>Not Sensitive (general items)</option>
                  <option>Moderately Sensitive (electronics, valuables)</option>
                  <option>Sensitive (documents, money, medicine)</option>
                  <option>Highly Sensitive (confidential, fragile)</option>
                </select>
              </div>
            </div>

            {/* Buttons */}
            <div style={{ display: 'flex', gap: 12, justifyContent: 'flex-end', marginTop: 24 }}>
              <button
                onClick={() => setEditModalOpen(false)}
                style={{ padding: '10px 20px', border: '1.5px solid #bfc2d9', background: '#fff', color: '#2563eb', borderRadius: 8, fontWeight: 600, cursor: 'pointer', transition: 'all 0.3s ease' }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.background = '#f3f4f6';
                  e.currentTarget.style.transform = 'scale(1.02)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.background = '#fff';
                  e.currentTarget.style.transform = 'scale(1)';
                }}
              >
                Cancel
              </button>
              <button
                onClick={handleSaveEdit}
                style={{ padding: '10px 20px', background: '#2563eb', color: '#fff', border: 'none', borderRadius: 8, fontWeight: 600, cursor: 'pointer', transition: 'all 0.3s ease' }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.background = '#1d4ed8';
                  e.currentTarget.style.transform = 'scale(1.05)';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.background = '#2563eb';
                  e.currentTarget.style.transform = 'scale(1)';
                }}
              >
                💾 Save Changes
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Contact Modal */}
      {showContactModal && (
        <div style={{
          position: 'fixed',
          top: 0,
          left: 0,
          right: 0,
          bottom: 0,
          background: 'rgba(0, 0, 0, 0.5)',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          zIndex: 1001
        }}>
          <div style={{
            background: '#fff',
            borderRadius: 12,
            padding: 28,
            maxWidth: 500,
            maxHeight: '80vh',
            overflowY: 'auto',
            boxShadow: '0 10px 40px rgba(0, 0, 0, 0.2)'
          }}>
            <h2 style={{ marginTop: 0, marginBottom: 8, fontSize: 22, color: '#1f2937', display: 'flex', alignItems: 'center', gap: 8 }}>
              <span>📞</span> Contact & Support
            </h2>
            <p style={{ color: '#6b7280', marginBottom: 20, fontSize: 14 }}>Have questions or need help? We're here for you!</p>

            <div style={{ fontSize: 14, color: '#374151', lineHeight: 1.8 }}>
              <div style={{ marginBottom: 18, paddingBottom: 18, borderBottom: '1px solid #e5e7eb' }}>
                <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                  <span style={{ fontSize: 20 }}>📧</span>
                  <div>
                    <p style={{ margin: '0 0 4px 0', fontWeight: 600, color: '#1f2937' }}>Email</p>
                    <p style={{ margin: 0, color: '#2563eb', wordBreak: 'break-all' }}>support@errandbridge.com</p>
                    <p style={{ margin: '4px 0 0 0', fontSize: 12, color: '#6b7280' }}>We respond within 24 hours</p>
                  </div>
                </div>
              </div>

              <div style={{ marginBottom: 18, paddingBottom: 18, borderBottom: '1px solid #e5e7eb' }}>
                <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                  <span style={{ fontSize: 20 }}>💬</span>
                  <div>
                    <p style={{ margin: '0 0 4px 0', fontWeight: 600, color: '#1f2937' }}>Chat</p>
                    <p style={{ margin: 0, color: '#374151' }}>Available in the app during business hours</p>
                    <p style={{ margin: '4px 0 0 0', fontSize: 12, color: '#6b7280' }}>Real-time support for urgent issues</p>
                  </div>
                </div>
              </div>

              <div style={{ marginBottom: 18, paddingBottom: 18, borderBottom: '1px solid #e5e7eb' }}>
                <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                  <span style={{ fontSize: 20 }}>📱</span>
                  <div>
                    <p style={{ margin: '0 0 4px 0', fontWeight: 600, color: '#1f2937' }}>Phone</p>
                    <p style={{ margin: 0, color: '#2563eb', fontWeight: 600 }}>+234 123 456 7890</p>
                    <p style={{ margin: '4px 0 0 0', fontSize: 12, color: '#6b7280' }}>For urgent matters</p>
                  </div>
                </div>
              </div>

              <div style={{ marginBottom: 18 }}>
                <div style={{ display: 'flex', alignItems: 'flex-start', gap: 12 }}>
                  <span style={{ fontSize: 20 }}>🕐</span>
                  <div>
                    <p style={{ margin: '0 0 4px 0', fontWeight: 600, color: '#1f2937' }}>Business Hours</p>
                    <p style={{ margin: 0, color: '#374151' }}>Monday - Friday</p>
                    <p style={{ margin: '2px 0 0 0', color: '#374151' }}>9:00 AM - 6:00 PM (WAT)</p>
                    <p style={{ margin: '4px 0 0 0', fontSize: 12, color: '#6b7280' }}>*Closed on weekends and holidays</p>
                  </div>
                </div>
              </div>

              <div style={{ background: '#fff3cd', border: '1px solid #ffeeba', borderRadius: 8, padding: 12, marginTop: 20 }}>
                <p style={{ margin: 0, fontSize: 13, color: '#856404' }}>
                  <strong>Reporting a complaint?</strong> Please have your errand ID ready and provide details about the issue. Our support team will investigate and get back to you within 48 hours.
                </p>
              </div>
            </div>

            <button
              onClick={() => setShowContactModal(false)}
              style={{
                width: '100%',
                padding: '12px 16px',
                background: '#2563eb',
                color: '#fff',
                border: 'none',
                borderRadius: 8,
                cursor: 'pointer',
                fontWeight: 500,
                fontSize: 14,
                marginTop: 24,
                transition: 'background-color 0.2s ease'
              }}
              onMouseEnter={(e) => e.target.style.background = '#1d4ed8'}
              onMouseLeave={(e) => e.target.style.background = '#2563eb'}
            >
              Close
            </button>
          </div>
        </div>
      )}

      {/* Policy Modal */}
      {showPolicyModal && (
        <div style={{
          position: 'fixed',
          top: 0,
          left: 0,
          right: 0,
          bottom: 0,
          background: 'rgba(0, 0, 0, 0.5)',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          zIndex: 1000
        }}>
          <div style={{
            background: '#fff',
            borderRadius: 12,
            padding: 28,
            maxWidth: 600,
            maxHeight: '80vh',
            overflowY: 'auto',
            boxShadow: '0 10px 40px rgba(0, 0, 0, 0.2)'
          }}>
            <h2 style={{ marginTop: 0, marginBottom: 16, fontSize: 24, color: '#1f2937' }}>
              Terms-Lite Pilot Policy
            </h2>

            <div style={{ fontSize: 14, lineHeight: 1.6, color: '#374151' }}>
              <h3 style={{ marginTop: 16, marginBottom: 8, color: '#1f2937' }}>1. Service Overview</h3>
              <p>ErrandBridge is a pilot service that connects users with local service providers for various errands and tasks. This service is provided on an "as-is" basis during the pilot phase.</p>

              <h3 style={{ marginTop: 16, marginBottom: 8, color: '#1f2937' }}>2. User Responsibilities</h3>
              <p>Users agree to:</p>
              <ul style={{ marginTop: 8, marginBottom: 8 }}>
                <li>Provide accurate information when creating errands</li>
                <li>Not request illegal or harmful services</li>
                <li>Maintain confidentiality of sensitive documents</li>
                <li>Respect the service providers' time and professionalism</li>
              </ul>

              <h3 style={{ marginTop: 16, marginBottom: 8, color: '#1f2937' }}>3. Data & Privacy</h3>
              <p>All documents and attachments are encrypted and access-restricted. Files are removed after errand completion. Your personal information is used solely for service delivery and will not be shared with third parties.</p>

              <h3 style={{ marginTop: 16, marginBottom: 8, color: '#1f2937' }}>4. Limitation of Liability</h3>
              <p>ErrandBridge is not liable for delays, service failures, or loss of documents. Users are responsible for uploading sensitive documents at their own risk.</p>

              <h3 style={{ marginTop: 16, marginBottom: 8, color: '#1f2937' }}>5. Service Provider</h3>
              <p>Service providers are independent contractors. ErrandBridge does not guarantee specific completion times or outcomes but will work to resolve disputes fairly.</p>

              <h3 style={{ marginTop: 16, marginBottom: 8, color: '#1f2937' }}>6. Changes to Terms</h3>
              <p>These terms may be updated during the pilot phase. Continued use of the service indicates acceptance of updated terms.</p>

              <p style={{ marginTop: 24, fontSize: 12, color: '#6b7280' }}>Last updated: January 1, 2026</p>
            </div>

            <div style={{ display: 'flex', gap: 12, marginTop: 24 }}>
              <button
                onClick={() => setShowPolicyModal(false)}
                style={{
                  flex: 1,
                  padding: '10px 16px',
                  border: '1px solid #d1d5db',
                  background: '#f3f4f6',
                  borderRadius: 8,
                  cursor: 'pointer',
                  fontWeight: 500,
                  fontSize: 14
                }}
              >
                Close
              </button>
              <button
                onClick={() => {
                  setAgreed(true);
                  setShowPolicyModal(false);
                }}
                style={{
                  flex: 1,
                  padding: '10px 16px',
                  background: '#2563eb',
                  color: '#fff',
                  border: 'none',
                  borderRadius: 8,
                  cursor: 'pointer',
                  fontWeight: 500,
                  fontSize: 14
                }}
              >
                I Accept & Agree
              </button>
            </div>
          </div>
        </div>
      )}

      {/* Review Modal - Shows after errand completion */}
      {reviewModalOpen && reviewErrand && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 32, minWidth: 340, maxWidth: 500, boxShadow: '0 4px 24px #0003', position: 'relative' }}>
            <button onClick={() => { setReviewModalOpen(false); setReviewErrand(null); }} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            
            <h3 style={{ fontWeight: 700, fontSize: 24, marginBottom: 8, color: '#10b981' }}>🎉 Errand Completed!</h3>
            <p style={{ fontSize: 14, color: '#666', marginBottom: 20 }}>Thank you for using ErrandBridge. Please share your feedback about this errand.</p>
            
            <form onSubmit={(e) => { e.preventDefault(); handleSubmitReview(); }}>
              {/* Errand Details */}
              <div style={{ background: '#f3f4f6', padding: 12, borderRadius: 8, marginBottom: 20 }}>
                <div style={{ fontWeight: 600, fontSize: 14, marginBottom: 4 }}>{reviewErrand.title}</div>
                <div style={{ fontSize: 12, color: '#666' }}>Reference: {reviewErrand.referenceNumber}</div>
              </div>
              
              {/* Rating */}
              <div style={{ marginBottom: 20 }}>
                <label style={{ fontWeight: 600, fontSize: 14, display: 'block', marginBottom: 10 }}>How would you rate this errand? ⭐</label>
                <div style={{ display: 'flex', gap: 8, justifyContent: 'center' }}>
                  {[1, 2, 3, 4, 5].map(star => (
                    <button
                      key={star}
                      type="button"
                      onClick={() => setReviewRating(star)}
                      style={{
                        fontSize: 32,
                        background: 'none',
                        border: 'none',
                        cursor: 'pointer',
                        opacity: star <= reviewRating ? 1 : 0.3,
                        transform: star <= reviewRating ? 'scale(1.1)' : 'scale(1)',
                        transition: 'all 0.2s'
                      }}
                      title={`${star} star${star !== 1 ? 's' : ''}`}
                    >
                      ⭐
                    </button>
                  ))}
                </div>
              </div>
              
              {/* Notes */}
              <div style={{ marginBottom: 20 }}>
                <label style={{ fontWeight: 600, fontSize: 14, display: 'block', marginBottom: 8 }}>Additional Comments (optional)</label>
                <textarea
                  value={reviewNotes}
                  onChange={(e) => setReviewNotes(e.target.value)}
                  placeholder="Tell us what you liked or what could be improved..."
                  maxLength="1000"
                  style={{
                    width: '100%',
                    padding: 12,
                    borderRadius: 8,
                    border: '1.5px solid #bfc2d9',
                    fontSize: 14,
                    fontFamily: 'inherit',
                    resize: 'vertical',
                    minHeight: '100px',
                    boxSizing: 'border-box'
                  }}
                />
                <div style={{ fontSize: 12, color: '#888', marginTop: 4, textAlign: 'right' }}>
                  {reviewNotes.length}/1000
                </div>
              </div>
              
              {/* Buttons */}
              <div style={{ display: 'flex', gap: 12 }}>
                <button
                  type="submit"
                  disabled={reviewSubmitting}
                  style={{
                    flex: 1,
                    background: '#10b981',
                    color: '#fff',
                    border: 'none',
                    borderRadius: 8,
                    padding: '12px 16px',
                    fontWeight: 600,
                    fontSize: 15,
                    cursor: reviewSubmitting ? 'not-allowed' : 'pointer',
                    opacity: reviewSubmitting ? 0.6 : 1,
                    transition: 'background 0.2s'
                  }}
                  onMouseEnter={(e) => !reviewSubmitting && (e.target.style.background = '#059669')}
                  onMouseLeave={(e) => !reviewSubmitting && (e.target.style.background = '#10b981')}
                >
                  {reviewSubmitting ? '⏳ Submitting...' : '✅ Submit Review'}
                </button>
                <button
                  type="button"
                  onClick={() => { setReviewModalOpen(false); setReviewErrand(null); }}
                  style={{
                    flex: 1,
                    background: '#f3f4f6',
                    color: '#666',
                    border: 'none',
                    borderRadius: 8,
                    padding: '12px 16px',
                    fontWeight: 600,
                    fontSize: 15,
                    cursor: 'pointer',
                    transition: 'background 0.2s'
                  }}
                  onMouseEnter={(e) => e.target.style.background = '#e5e7eb'}
                  onMouseLeave={(e) => e.target.style.background = '#f3f4f6'}
                >
                  Skip
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* ✅ ERRAND SUBMISSION CONFIRMATION MODAL */}
      {submissionConfirmOpen && submittedErrandData && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 40, maxWidth: 500, width: '90%', boxShadow: '0 8px 32px #0003', textAlign: 'center', position: 'relative' }}>
            <button onClick={() => setSubmissionConfirmOpen(false)} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 22, cursor: 'pointer', color: '#888' }}>&times;</button>
            
            {/* Success Icon */}
            <div style={{ fontSize: 64, marginBottom: 16 }}>✅</div>
            
            {/* Status Badge */}
            <div style={{ 
              display: 'inline-block', 
              background: '#dcfce7', 
              color: '#166534', 
              padding: '6px 12px', 
              borderRadius: 6, 
              fontSize: 12, 
              fontWeight: 600, 
              marginBottom: 16,
              textTransform: 'uppercase',
              letterSpacing: '0.5px'
            }}>
              📋 {submittedErrandData.status || 'PENDING'}
            </div>
            
            {/* Title */}
            <h2 style={{ fontWeight: 700, fontSize: 24, marginBottom: 8, color: '#1f2937' }}>Errand Submitted!</h2>
            <p style={{ color: '#666', fontSize: 14, marginBottom: 24, lineHeight: 1.6 }}>
              Your errand has been successfully submitted and is pending verification. You'll receive updates via email.
            </p>
            
            {/* Details Box */}
            <div style={{ 
              background: '#f9fafb', 
              borderRadius: 12, 
              padding: 16, 
              marginBottom: 24,
              border: '1px solid #e5e7eb'
            }}>
              <div style={{ marginBottom: 12 }}>
                <div style={{ fontSize: 12, color: '#888', marginBottom: 4 }}>Errand Title</div>
                <div style={{ fontSize: 15, fontWeight: 600, color: '#1f2937' }}>{submittedErrandData.title}</div>
              </div>
              <div>
                <div style={{ fontSize: 12, color: '#888', marginBottom: 4 }}>Reference Number</div>
                <div style={{ fontSize: 14, fontWeight: 500, color: '#2563eb', fontFamily: 'monospace' }}>{submittedErrandData.referenceNumber}</div>
              </div>
            </div>
            
            {/* Info Message */}
            <div style={{ 
              background: '#fef3c7', 
              border: '1px solid #fcd34d',
              borderRadius: 8, 
              padding: 12, 
              marginBottom: 24,
              fontSize: 13,
              color: '#92400e',
              lineHeight: 1.5
            }}>
              📌 <strong>What's next?</strong> Keep your reference number handy. You can track your errand status in the "My Errands" section.
            </div>
            
            {/* Action Buttons */}
            <div style={{ display: 'flex', gap: 12, justifyContent: 'center' }}>
              <button 
                onClick={() => {
                  setSubmissionConfirmOpen(false);
                  // Clear form
                  setTitle('');
                  setNote('');
                  setTemplate('Official Document / Office Pickup');
                  setSensitivity('Sensitive (documents, money, medicine)');
                  setPickup('');
                  setDropoff('');
                  setAgreed(false);
                }}
                style={{ 
                  flex: 1,
                  maxWidth: 200,
                  background: '#2563eb', 
                  color: '#fff', 
                  border: 'none', 
                  borderRadius: 8, 
                  padding: '12px 16px', 
                  fontWeight: 600, 
                  fontSize: 14, 
                  cursor: 'pointer',
                  transition: 'background 0.2s'
                }}
                onMouseEnter={(e) => e.currentTarget.style.background = '#1d4ed8'}
                onMouseLeave={(e) => e.currentTarget.style.background = '#2563eb'}
              >
                ✅ Done
              </button>
              <button 
                onClick={() => {
                  setSubmissionConfirmOpen(false);
                  // Optionally scroll to My Errands section
                  const myErrandsSection = document.querySelector('[data-section="my-errands"]');
                  if (myErrandsSection) {
                    myErrandsSection.scrollIntoView({ behavior: 'smooth' });
                  }
                }}
                style={{ 
                  flex: 1,
                  maxWidth: 200,
                  background: '#f3f4f6', 
                  color: '#2563eb', 
                  border: '1.5px solid #2563eb', 
                  borderRadius: 8, 
                  padding: '12px 16px', 
                  fontWeight: 600, 
                  fontSize: 14, 
                  cursor: 'pointer',
                  transition: 'all 0.2s'
                }}
                onMouseEnter={(e) => {
                  e.currentTarget.style.background = '#eff6ff';
                  e.currentTarget.style.borderColor = '#1d4ed8';
                }}
                onMouseLeave={(e) => {
                  e.currentTarget.style.background = '#f3f4f6';
                  e.currentTarget.style.borderColor = '#2563eb';
                }}
              >
                📊 View My Errands
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ADMIN DASHBOARD MODAL */}
      {adminDashboardOpen && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: '#0007', zIndex: 1000, display: 'flex', alignItems: 'center', justifyContent: 'center', overflowY: 'auto', paddingTop: 20, paddingBottom: 20 }}>
          <div style={{ background: '#fff', borderRadius: 16, padding: 24, maxWidth: 1200, width: '95%', boxShadow: '0 8px 32px #0003', position: 'relative' }}>
            {/* Close Button */}
            <button onClick={() => setAdminDashboardOpen(false)} style={{ position: 'absolute', top: 12, right: 16, background: 'none', border: 'none', fontSize: 28, cursor: 'pointer', color: '#888' }}>&times;</button>
            
            {/* Header */}
            <h1 style={{ fontSize: 28, fontWeight: 700, marginBottom: 24, color: '#1f2937' }}>👨‍💼 Admin Dashboard</h1>
            
            {/* Tab Navigation */}
            <div style={{ display: 'flex', gap: 8, marginBottom: 24, borderBottom: '1px solid #e5e7eb', paddingBottom: 12, overflowX: 'auto' }}>
              {['customers', 'errands', 'attachments', 'issues', 'stats'].map(tab => (
                <button
                  key={tab}
                  onClick={() => setAdminTab(tab)}
                  style={{
                    padding: '8px 16px',
                    border: 'none',
                    borderBottom: adminTab === tab ? '3px solid #8b5cf6' : 'none',
                    background: 'none',
                    cursor: 'pointer',
                    fontWeight: adminTab === tab ? 600 : 400,
                    color: adminTab === tab ? '#8b5cf6' : '#666',
                    fontSize: 14,
                    transition: 'all 0.2s'
                  }}
                  onMouseEnter={(e) => { e.target.style.color = '#8b5cf6'; }}
                  onMouseLeave={(e) => { e.target.style.color = adminTab === tab ? '#8b5cf6' : '#666'; }}
                >
                  {tab === 'customers' && '👥 Customers'}
                  {tab === 'errands' && '📦 Errands'}
                  {tab === 'attachments' && '📎 Attachments'}
                  {tab === 'issues' && '🔍 Issues'}
                  {tab === 'stats' && '📊 Statistics'}
                </button>
              ))}
            </div>

            {/* Content Loading */}
            {adminLoading && (
              <div style={{ textAlign: 'center', padding: '40px 20px' }}>
                <div style={{ fontSize: 24 }}>⏳ Loading...</div>
              </div>
            )}

            {/* CUSTOMERS TAB */}
            {adminTab === 'customers' && !adminLoading && (
              <div style={{ overflowX: 'auto' }}>
                <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 14 }}>
                  <thead>
                    <tr style={{ background: '#f3f4f6', borderBottom: '2px solid #e5e7eb' }}>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>ID</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Email</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Name</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Phone</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>City</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Verified</th>
                    </tr>
                  </thead>
                  <tbody>
                    {adminCustomers.map(cust => (
                      <tr key={cust.id} style={{ borderBottom: '1px solid #e5e7eb', '&:hover': { background: '#fafafa' } }}>
                        <td style={{ padding: '12px' }}>{cust.id}</td>
                        <td style={{ padding: '12px' }}>{cust.email}</td>
                        <td style={{ padding: '12px' }}>{cust.first_name} {cust.last_name}</td>
                        <td style={{ padding: '12px' }}>{cust.phone || '-'}</td>
                        <td style={{ padding: '12px' }}>{cust.city || '-'}</td>
                        <td style={{ padding: '12px' }}>
                          <span style={{ 
                            display: 'inline-block',
                            padding: '4px 8px',
                            borderRadius: 4,
                            fontSize: 12,
                            fontWeight: 600,
                            background: cust.is_email_verified ? '#dcfce7' : '#fee2e2',
                            color: cust.is_email_verified ? '#166534' : '#991b1b'
                          }}>
                            {cust.is_email_verified ? '✓ Yes' : '✗ No'}
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                {adminCustomers.length === 0 && (
                  <div style={{ textAlign: 'center', padding: '40px 20px', color: '#999' }}>No customers found</div>
                )}
              </div>
            )}

            {/* ERRANDS TAB */}
            {adminTab === 'errands' && !adminLoading && (
              <div style={{ overflowX: 'auto' }}>
                <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 13 }}>
                  <thead>
                    <tr style={{ background: '#f3f4f6', borderBottom: '2px solid #e5e7eb' }}>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>ID</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Title</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Status</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Pickup</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Dropoff</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {adminErrandsList.map(errand => (
                      <tr key={errand.id} style={{ borderBottom: '1px solid #e5e7eb' }}>
                        <td style={{ padding: '12px' }}>{errand.id}</td>
                        <td style={{ padding: '12px' }}>{errand.title?.substring(0, 30)}</td>
                        <td style={{ padding: '12px' }}>
                          <span style={{ 
                            display: 'inline-block',
                            padding: '4px 8px',
                            borderRadius: 4,
                            fontSize: 11,
                            fontWeight: 600,
                            background: errand.status === 'submitted' ? '#e0e7ff' : errand.status === 'assigned' ? '#dbeafe' : '#dcfce7',
                            color: errand.status === 'submitted' ? '#312e81' : errand.status === 'assigned' ? '#0c4a6e' : '#166534'
                          }}>
                            {errand.status?.toUpperCase()}
                          </span>
                        </td>
                        <td style={{ padding: '12px', fontSize: 12 }}>{errand.pickupLocation?.substring(0, 20)}</td>
                        <td style={{ padding: '12px', fontSize: 12 }}>{errand.dropoffLocation?.substring(0, 20)}</td>
                        <td style={{ padding: '12px' }}>
                          {errand.status === 'submitted' && (
                            <button onClick={() => handleAssignErrand(errand.id)} style={{ padding: '4px 8px', fontSize: 11, background: '#dbeafe', border: '1px solid #0c4a6e', borderRadius: 4, cursor: 'pointer', fontWeight: 600, color: '#0c4a6e' }}>
                              ✋ Assign
                            </button>
                          )}
                          {errand.status === 'assigned' && (
                            <button onClick={() => handleApproveErrand(errand.id)} style={{ padding: '4px 8px', fontSize: 11, background: '#dcfce7', border: '1px solid #166534', borderRadius: 4, cursor: 'pointer', fontWeight: 600, color: '#166534' }}>
                              ✅ Approve
                            </button>
                          )}
                          {errand.status === 'approved' && (
                            <span style={{ fontSize: 11, color: '#999' }}>-</span>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                {adminErrandsList.length === 0 && (
                  <div style={{ textAlign: 'center', padding: '40px 20px', color: '#999' }}>No errands found</div>
                )}
              </div>
            )}

            {/* ATTACHMENTS TAB */}
            {adminTab === 'attachments' && !adminLoading && (
              <div style={{ overflowX: 'auto' }}>
                <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 13 }}>
                  <thead>
                    <tr style={{ background: '#f3f4f6', borderBottom: '2px solid #e5e7eb' }}>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>ID</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Filename</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Size</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Errand ID</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {adminAttachments.map(att => (
                      <tr key={att.id} style={{ borderBottom: '1px solid #e5e7eb' }}>
                        <td style={{ padding: '12px' }}>{att.id}</td>
                        <td style={{ padding: '12px' }}>{att.filename?.substring(0, 30)}</td>
                        <td style={{ padding: '12px', fontSize: 12 }}>{(att.sizeBytes / 1024 / 1024).toFixed(2)} MB</td>
                        <td style={{ padding: '12px' }}>{att.errand_id}</td>
                        <td style={{ padding: '12px', display: 'flex', gap: 6 }}>
                          <button onClick={() => handleReviewAttachment(att.id, 'approve')} style={{ padding: '4px 8px', fontSize: 11, background: '#dcfce7', border: '1px solid #166534', borderRadius: 4, cursor: 'pointer', fontWeight: 600, color: '#166534' }}>
                            ✅
                          </button>
                          <button onClick={() => handleReviewAttachment(att.id, 'reject')} style={{ padding: '4px 8px', fontSize: 11, background: '#fee2e2', border: '1px solid #991b1b', borderRadius: 4, cursor: 'pointer', fontWeight: 600, color: '#991b1b' }}>
                            ✗
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                {adminAttachments.length === 0 && (
                  <div style={{ textAlign: 'center', padding: '40px 20px', color: '#999' }}>No attachments found</div>
                )}
              </div>
            )}

            {/* ISSUES TAB */}
            {adminTab === 'issues' && !adminLoading && (
              <div style={{ overflowX: 'auto' }}>
                <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: 13 }}>
                  <thead>
                    <tr style={{ background: '#f3f4f6', borderBottom: '2px solid #e5e7eb' }}>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>ID</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Type</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Description</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Status</th>
                      <th style={{ padding: '12px', textAlign: 'left', fontWeight: 600, color: '#374151' }}>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {adminIssues.map(issue => (
                      <tr key={issue.id} style={{ borderBottom: '1px solid #e5e7eb' }}>
                        <td style={{ padding: '12px' }}>{issue.id}</td>
                        <td style={{ padding: '12px' }}>{issue.type || '-'}</td>
                        <td style={{ padding: '12px', fontSize: 12 }}>{issue.description?.substring(0, 40)}</td>
                        <td style={{ padding: '12px' }}>
                          <span style={{ 
                            display: 'inline-block',
                            padding: '4px 8px',
                            borderRadius: 4,
                            fontSize: 11,
                            fontWeight: 600,
                            background: issue.status === 'open' ? '#fee2e2' : '#dcfce7',
                            color: issue.status === 'open' ? '#991b1b' : '#166534'
                          }}>
                            {issue.status?.toUpperCase()}
                          </span>
                        </td>
                        <td style={{ padding: '12px', display: 'flex', gap: 6 }}>
                          {issue.status === 'open' && (
                            <>
                              <button onClick={() => handleResolveIssue(issue.id, 'resolved')} style={{ padding: '4px 8px', fontSize: 11, background: '#dcfce7', border: '1px solid #166534', borderRadius: 4, cursor: 'pointer', fontWeight: 600, color: '#166534' }}>
                                ✓
                              </button>
                              <button onClick={() => handleResolveIssue(issue.id, 'rejected')} style={{ padding: '4px 8px', fontSize: 11, background: '#fee2e2', border: '1px solid #991b1b', borderRadius: 4, cursor: 'pointer', fontWeight: 600, color: '#991b1b' }}>
                                ✗
                              </button>
                            </>
                          )}
                          {issue.status !== 'open' && (
                            <span style={{ fontSize: 11, color: '#999' }}>-</span>
                          )}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
                {adminIssues.length === 0 && (
                  <div style={{ textAlign: 'center', padding: '40px 20px', color: '#999' }}>No issues found</div>
                )}
              </div>
            )}

            {/* STATISTICS TAB */}
            {adminTab === 'stats' && !adminLoading && (
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: 16 }}>
                <div style={{ background: '#f3f4f6', borderRadius: 12, padding: 20, textAlign: 'center' }}>
                  <div style={{ fontSize: 32, fontWeight: 700, color: '#2563eb' }}>{adminStats?.total_users || 0}</div>
                  <div style={{ fontSize: 14, color: '#666', marginTop: 8 }}>Total Users</div>
                </div>
                <div style={{ background: '#f3f4f6', borderRadius: 12, padding: 20, textAlign: 'center' }}>
                  <div style={{ fontSize: 32, fontWeight: 700, color: '#10b981' }}>{adminStats?.verified_users || 0}</div>
                  <div style={{ fontSize: 14, color: '#666', marginTop: 8 }}>Verified Users</div>
                </div>
                <div style={{ background: '#f3f4f6', borderRadius: 12, padding: 20, textAlign: 'center' }}>
                  <div style={{ fontSize: 32, fontWeight: 700, color: '#f59e0b' }}>{adminStats?.pending_issues || 0}</div>
                  <div style={{ fontSize: 14, color: '#666', marginTop: 8 }}>Pending Issues</div>
                </div>
                <div style={{ background: '#f3f4f6', borderRadius: 12, padding: 20, textAlign: 'center' }}>
                  <div style={{ fontSize: 32, fontWeight: 700, color: '#8b5cf6' }}>{adminStats?.total_errands || 0}</div>
                  <div style={{ fontSize: 14, color: '#666', marginTop: 8 }}>Total Errands</div>
                </div>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

export default App;
