<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only manifest overlay.

  Enables cleartext traffic so Capacitor live-reload / local dev APIs over http://
  work in Android Studio debug builds.

  Release builds keep the stricter defaults from src/main/AndroidManifest.xml.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config" />

</manifest>
