  async function handleAuthSubmit(e) {
    e.preventDefault();
    if (resetPwMode) {
      setResetPwMode(false);
      setAuthModalOpen(false);
      setResetPwEmail('');
      return;
    }
    
    // Call backend authentication
    const endpoint = authMode === 'login' ? '/auth/login' : '/auth/signup';
    const payload = authMode === 'login' 
      ? { email: authEmail, password: authPassword }
      : { 
          email: authEmail, 
          password: authPassword,
          first_name: authFirstName,
          last_name: authLastName,
          phone: authPhone,
          address_line1: authAddressLine,
          city: authCity,
          country: authCountry,
          postal_code: authPostcode
        };

    console.log(`[AUTH] ${authMode === 'login' ? 'LOGIN' : 'SIGNUP'} - Sending request to ${endpoint}`, payload);

    try {
      const res = await fetch(`http://localhost:8001${endpoint}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      console.log(`[AUTH] Response received:`, data);
      
      // After signup, show email verification modal
      if (authMode === 'signup' && data.access_token && !data.error) {
        console.log(`[AUTH] Signup successful - showing verification modal for ${authEmail}`);
        setPendingVerificationEmail(authEmail);
        setShowVerificationModal(true);
        setVerificationCode('');
        setVerificationError('');
        // Clear password from auth modal (but keep email and names)
        setAuthPassword('');
        return;
      }
      
      if (data.access_token) {
        // Store token and user info (for login)
        console.log('[LOGIN] Storing auth token and user info to cache');
        console.log('[LOGIN] Token:', data.access_token.substring(0, 50) + '...');
        console.log('[LOGIN] User ID:', data.user_id);
        
        // Use new cache system - stores email, names with auto-expire
        cache.setAuthToken(data.access_token, data.expires_in || 86400);
        cache.setUserField('email', data.email);
        cache.setUserField('firstName', data.first_name || authFirstName);
        cache.setUserField('lastName', data.last_name || authLastName);
        
        // Also set full profile for later use
        const profileData = {
          email: data.email,
          firstName: data.first_name || authFirstName,
          lastName: data.last_name || authLastName,
          ...(data.address && { address: data.address }),
          ...(data.city && { city: data.city }),
          ...(data.country && { country: data.country }),
          ...(data.phone && { phone: data.phone }),
          ...(data.postal_code && { postcode: data.postal_code }),
        };
        cache.setUserProfile(profileData);
        
        // Keep legacy localStorage for backward compatibility
        localStorage.setItem('authToken', data.access_token);
        localStorage.setItem('userId', data.user_id);
        
        console.log('[LOGIN] Verifying cache was set:');
        console.log('[LOGIN] Auth token in cache:', cache.getAuthToken() ? 'YES' : 'NO');
        
        // Set user state
        setUser({ 
          id: data.user_id,
          firstName: data.first_name || authFirstName, 
          lastName: data.last_name || authLastName, 
          email: data.email 
        });
        
        setAuthModalOpen(false);
        setAuthEmail(''); 
        setAuthPassword(''); 
        setAuthFirstName(''); 
        setAuthLastName('');
        
        console.log('[LOGIN] Calling loadUserProfile()...');
        // Load full user profile from backend
        await loadUserProfile();
        
        console.log('[LOGIN] Calling fetchErrands()...');
        // Refresh errands with new token
        fetchErrands();
      } else if (data.error || data.detail) {
        alert('Auth error: ' + (data.error || data.detail));
      }
    } catch (err) {
      console.error('[AUTH] Error:', err);
      alert('Auth failed: ' + err.message);
    }
  }

  // Handle email verification after signup
  async function handleVerifyEmail(e) {
    e.preventDefault();
    console.log(`[VERIFY] Attempting to verify code for ${pendingVerificationEmail}: ${verificationCode}`);
    
    if (!verificationCode.trim()) {
      console.log(`[VERIFY] Error: No code entered`);
      setVerificationError('Please enter the verification code');
      return;
    }

    try {
      const res = await fetch('http://localhost:8001/auth/confirm', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: pendingVerificationEmail,
          code: verificationCode.trim()
        })
      });
      
      const data = await res.json();
      console.log(`[VERIFY] Response status: ${res.status}, data:`, data);
      
      if (data.ok || res.ok) {
        // Email verified successfully
        console.log(`[VERIFY] Success! Email verified.`);
        setVerificationError('');
        setShowVerificationModal(false);
        setVerificationCode('');
        setAuthMode('login');
        alert('Email verified! Please log in with your credentials.');
      } else {
        console.log(`[VERIFY] Error: ${data.detail}`);
        setVerificationError(data.detail || 'Invalid code. Please try again.');
      }
    } catch (err) {
      console.error(`[VERIFY] Exception:`, err);
      setVerificationError('Verification failed: ' + err.message);
    }
  }

  // Handle resending verification code
  async function handleResendVerificationCode() {
    try {
      const res = await fetch('http://localhost:8001/auth/resend', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: pendingVerificationEmail })
      });
      
      const data = await res.json();
      if (data.ok || res.ok) {
        setVerificationError('');
        alert('New code sent to ' + pendingVerificationEmail);
      } else {
        setVerificationError(data.detail || 'Failed to resend code');
      }
    } catch (err) {
      setVerificationError('Resend failed: ' + err.message);
    }
  }

  // Handle password change
  async function handleChangePassword(e) {
    e.preventDefault();
    setChangePasswordError('');
    setChangePasswordSuccess('');

    // Validate form
    if (!changePasswordCurrentPassword.trim()) {
      setChangePasswordError('Please enter your current password');
      return;
    }
    if (!changePasswordNewPassword.trim()) {
      setChangePasswordError('Please enter a new password');
      return;
    }
    if (changePasswordNewPassword.length < 8) {
      setChangePasswordError('New password must be at least 8 characters');
      return;
    }
    if (changePasswordNewPassword !== changePasswordConfirmPassword) {
      setChangePasswordError('Passwords do not match');
      return;
    }
    if (changePasswordNewPassword === changePasswordCurrentPassword) {
      setChangePasswordError('New password must be different from current password');
      return;
    }

    try {
      const token = localStorage.getItem('authToken');
      const res = await fetch('http://localhost:8001/auth/change-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          current_password: changePasswordCurrentPassword,
          new_password: changePasswordNewPassword
        })
      });

      const data = await res.json();
      
      if (res.ok || data.ok) {
        setChangePasswordSuccess('Password changed successfully!');
        setChangePasswordCurrentPassword('');
        setChangePasswordNewPassword('');
        setChangePasswordConfirmPassword('');
        setTimeout(() => {
          setShowChangePassword(false);
          setChangePasswordSuccess('');
        }, 2000);
      } else {
        setChangePasswordError(data.detail || data.error || 'Failed to change password');
      }
    } catch (err) {
      setChangePasswordError('Error: ' + err.message);
    }
  }

  // Settings modal: allow editing and saving customer info
  // Removed unused: editMode
  const [editFirstName, setEditFirstName] = useState(user ? user.firstName : '');
  const [editLastName, setEditLastName] = useState(user ? user.lastName : '');
  const [editEmail, setEditEmail] = useState(user ? user.email : '');
  const [editAddress, setEditAddress] = useState(user && user.address ? user.address : '');
  const [editCity, setEditCity] = useState(user && user.city ? user.city : '');
  const [editCountry, setEditCountry] = useState(user && user.country ? user.country : '');
  const [editPostcode, setEditPostcode] = useState(user && user.postcode ? user.postcode : '');
  const [editPhone, setEditPhone] = useState(user && user.phone ? user.phone : '');

  // Load user data when settings modal opens
  React.useEffect(() => {
    if (settingsOpen && user) {
      setEditFirstName(user.firstName || '');
      setEditLastName(user.lastName || '');
      setEditEmail(user.email || '');
      setEditAddress(user.address || '');
      setEditCity(user.city || '');
      setEditCountry(user.country || '');
      setEditPostcode(user.postcode || '');
      setEditPhone(user.phone || '');
    }
  }, [settingsOpen, user]);

  function handleSaveSettings(e) {
    e.preventDefault();
    setUser({
      ...user,
      firstName: editFirstName,
      lastName: editLastName,
      email: editEmail,
      address: editAddress,
      city: editCity,
      country: editCountry,
      postcode: editPostcode,
      phone: editPhone
    });
  }

  // Handle account deactivation
  async function handleDeactivateAccount() {
    const confirmDeactivate = window.confirm(
      '⚠️ WARNING: Deactivating your account will:\n\n' +
      '• Permanently delete your profile data\n' +
      '• Archive all your errands\n' +
      '• Make your account inaccessible\n\n' +
      'This action CANNOT be undone. Are you sure?'
    );
    
    if (!confirmDeactivate) return;
    
    const confirmAgain = window.prompt(
      'Type "DEACTIVATE" to confirm permanent account deletion:'
    );
    
    if (confirmAgain !== 'DEACTIVATE') {
      alert('Account deactivation cancelled.');
      return;
    }
    
    try {
      const token = localStorage.getItem('authToken');
      const response = await fetch('http://localhost:8001/auth/deactivate', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        }
      });
      
      const data = await response.json();
      if (response.ok) {
        setToast('✅ Account deactivated successfully. You have been logged out.');
        // Clear local storage
        localStorage.removeItem('authToken');
        localStorage.removeItem('userId');
        localStorage.removeItem('userName');
        cache.clearCache();
        // Logout
        setUser(null);
        setSettingsOpen(false);
      } else {
        alert(`Error: ${data.detail || 'Failed to deactivate account'}`);
      }
    } catch (err) {
      console.error('Deactivation error:', err);
      alert('Failed to deactivate account. Please try again.');
    }
  }

  // Handle profile image upload
  function handleProfileImageUpload(e) {
    const file = e.target.files?.[0];
    if (file) {
      // Check file size (max 5MB)
      if (file.size > 5 * 1024 * 1024) {
        alert('Image size must be less than 5MB');
        return;
      }

      // Check file type
      if (!file.type.startsWith('image/')) {
        alert('Please upload an image file');
        return;
      }

      const reader = new FileReader();
      reader.onload = (event) => {
        const imageData = event.target?.result;
        if (imageData) {
          setProfileImage(imageData);
          localStorage.setItem('profileImage', imageData);
        }
      };
      reader.readAsDataURL(file);
    }
  }

  // Admin Dashboard Functions
  async function loadAdminData() {
    setAdminLoading(true);
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        return;
      }

      const headers = {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      };

      // Load all admin data based on current tab
      if (adminTab === 'customers') {
        const res = await fetch('http://localhost:8001/admin/customers', { headers });
        const data = await res.json();
        setAdminCustomers(data.customers || []);
      } else if (adminTab === 'errands') {
        const res = await fetch('http://localhost:8001/admin/errands', { headers });
        const data = await res.json();
        setAdminErrandsList(data.errands || []);
      } else if (adminTab === 'attachments') {
        const res = await fetch('http://localhost:8001/admin/attachments', { headers });
        const data = await res.json();
        setAdminAttachments(data.attachments || []);
      } else if (adminTab === 'issues') {
        const res = await fetch('http://localhost:8001/admin/issues', { headers });
        const data = await res.json();
        setAdminIssues(data.issues || []);
      } else if (adminTab === 'stats') {
        const res = await fetch('http://localhost:8001/admin/customers/stats', { headers });
        const data = await res.json();
        setAdminStats(data);
      }
    } catch (err) {
      console.error('Error loading admin data:', err);
      alert('Failed to load admin data');
    }
    setAdminLoading(false);
  }

  // Reload admin data when tab changes
  React.useEffect(() => {
    if (adminDashboardOpen) {
      loadAdminData();
    }
  }, [adminTab, adminDashboardOpen]);

  async function handleApproveErrand(errandId) {
    const mutation = `mutation { approveErrand(errandId: ${errandId}) { id status assignedTo assignedAt } }`;
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        return;
      }
      
      const response = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ query: mutation })
      });
      
      const data = await response.json();
      if (data.errors) {
        alert(`Error approving errand: ${data.errors[0]?.message || 'Unknown error'}`);
        return;
      }
      
      if (data.data && data.data.approveErrand) {
        alert('✅ Errand approved!');
        loadAdminData();
      }
    } catch (err) {
      console.error('Error approving errand:', err);
      alert('Failed to approve errand. Please try again.');
    }
  }

  async function handleReviewAttachment(attachmentId, action) {
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        return;
      }
      
      const response = await fetch(`http://localhost:8001/admin/attachments/${attachmentId}/review`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ action })
      });
      
      const data = await response.json();
      if (response.ok) {
        alert(`✅ Attachment ${action === 'approve' ? 'approved' : 'rejected'}!`);
        loadAdminData();
      } else {
        alert(`Error: ${data.detail || 'Failed to review attachment'}`);
      }
    } catch (err) {
      console.error('Error reviewing attachment:', err);
      alert('Failed to review attachment. Please try again.');
    }
  }

  async function handleResolveIssue(issueId, resolution) {
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        return;
      }
      
      const response = await fetch(`http://localhost:8001/admin/issues/${issueId}/resolve`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ resolution })
      });
      
      const data = await response.json();
      if (response.ok) {
        alert(`✅ Issue resolved as: ${resolution}!`);
        loadAdminData();
      } else {
        alert(`Error: ${data.detail || 'Failed to resolve issue'}`);
      }
    } catch (err) {
      console.error('Error resolving issue:', err);
      alert('Failed to resolve issue. Please try again.');
    }
  }

  return (
    <div style={{ fontFamily: "system-ui, sans-serif", background: "#f7f8fa", minHeight: "100vh" }}>
      {/* Header */}
      <header style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "24px 36px 0 36px", background: "transparent", borderBottom: "none", minHeight: 80 }}>
        <div style={{ display: "flex", alignItems: "center" }}>
          <button 
            onClick={() => window.scrollTo({ top: 0, behavior: 'smooth' })}
            style={{ 
              background: 'none', 
              border: 'none', 
              padding: 0, 
              cursor: 'pointer',
              transition: 'transform 0.3s ease, box-shadow 0.3s ease',
              borderRadius: 14,
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center'
            }}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 4px 16px rgba(0,0,0,0.1)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = 'none';
            }}
            title="Go to home"
          >
            <img src={require('./errandbridge_logo_full.png')} alt="ErrandBridge Logo" style={{ height: 90, background: '#fff', borderRadius: 14, boxShadow: '0 2px 8px #0001', padding: 6, display: 'block' }} />
          </button>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 14 }}>
          {user && (
            <button 
              onClick={() => setUserDetailsOpen(true)}
              style={{ 
                background: 'none', 
                border: 'none', 
                padding: '6px 12px', 
                cursor: 'pointer',
                transition: 'transform 0.3s ease, box-shadow 0.3s ease',
                borderRadius: 8,
                fontWeight: 600,
                fontSize: 16,
                color: '#2563eb',
                marginRight: 0
              }}
              onMouseEnter={(e) => {
                e.currentTarget.style.transform = 'scale(1.05)';
                e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
              }}
              onMouseLeave={(e) => {
                e.currentTarget.style.transform = 'scale(1)';
                e.currentTarget.style.boxShadow = 'none';
              }}
              title="Click to view your details"
            >
              {user.firstName} {user.lastName}
            </button>
          )}
          {userIsAdmin && (
            <button 
              style={{ ...buttonStyle, background: '#8b5cf6', color: '#fff', transition: 'transform 0.3s ease' }} 
              onClick={() => setAdminDashboardOpen(true)}
              onMouseEnter={(e) => {
                e.currentTarget.style.transform = 'scale(1.05)';
                e.currentTarget.style.boxShadow = '0 2px 8px rgba(139, 92, 246, 0.2)';
              }}
              onMouseLeave={(e) => {
                e.currentTarget.style.transform = 'scale(1)';
                e.currentTarget.style.boxShadow = 'none';
              }}
              title="Admin Dashboard"
            >
              👨‍💼 Admin
            </button>
          )}
          <button 
            style={{ ...buttonStyle, transition: 'transform 0.3s ease' }} 
            onClick={() => setPuzzleOpen(true)}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = 'none';
            }}
          >
            Puzzle
          </button>
          <button 
            style={{ ...buttonStyle, transition: 'transform 0.3s ease' }} 
            onClick={() => setSettingsOpen(true)}
            onMouseEnter={(e) => {
              e.currentTarget.style.transform = 'scale(1.05)';
              e.currentTarget.style.boxShadow = '0 2px 8px rgba(37, 99, 235, 0.2)';
            }}
            onMouseLeave={(e) => {
              e.currentTarget.style.transform = 'scale(1)';
              e.currentTarget.style.boxShadow = 'none';
            }}
          >
            Settings
          </button>
          {user ? (
            <button
              style={{ ...buttonStyle, background: "#e74c3c", color: "#fff", transition: 'transform 0.3s ease' }}
              onClick={() => { 
                // Clear localStorage to prevent auto-login on refresh
                localStorage.removeItem('authToken');
                localStorage.removeItem('lastCustomerEmail');
                localStorage.removeItem('lastCustomerFirstName');
                localStorage.removeItem('lastCustomerLastName');
                localStorage.removeItem('userId');
                localStorage.removeItem('customerErrands');
                setUser(null);
              }}
              onMouseEnter={(e) => {
                e.currentTarget.style.transform = 'scale(1.05)';
                e.currentTarget.style.boxShadow = '0 2px 8px rgba(220, 38, 38, 0.2)';
              }}
              onMouseLeave={(e) => {
                e.currentTarget.style.transform = 'scale(1)';
                e.currentTarget.style.boxShadow = 'none';
              }}
            >
              Logout
            </button>
          ) : (
            <>
              <button
                style={{ ...buttonStyle, background: "#2563eb", color: "#fff" }}
                onClick={() => { setAuthMode('signup'); setAuthModalOpen(true); }}
              >
                Sign Up
              </button>
              <button
                style={{ ...buttonStyle, background: "#f3f4f6", color: "#2563eb" }}
                onClick={() => { setAuthMode('login'); setAuthModalOpen(true); }}
              >
                Login
              </button>
            </>
          )}
        </div>
      </header>
      
      {/* User Details Modal */}
      {userDetailsOpen && user && (
        <div style={{ position: 'fixed', top: 0, left: 0, width: '100vw', height: '100vh', background: 'rgba(0,0,0,0.5)', zIndex: 1100, display: 'flex', alignItems: 'center', justifyContent: 'center', transition: 'background 0.3s' }}>
          <div style={{ background: '#fff', borderRadius: 20, padding: '40px 36px', minWidth: 380, maxWidth: 500, boxShadow: '0 12px 40px rgba(0,0,0,0.15)', position: 'relative', animation: 'fadeInModal 0.35s' }}>
            <button 
              onClick={() => setUserDetailsOpen(false)} 
              style={{ position: 'absolute', top: 16, right: 16, background: 'none', border: 'none', fontSize: 28, cursor: 'pointer', color: '#999', transition: 'color 0.2s' }}
              onMouseEnter={(e) => e.target.style.color = '#2563eb'}
              onMouseLeave={(e) => e.target.style.color = '#999'}
            >
              ×
            </button>
            
            {/* Header with Profile Image */}
            <div style={{ textAlign: 'center', marginBottom: 28 }}>
              <div style={{ position: 'relative', display: 'inline-block', marginBottom: 16 }}>
                <div style={{ 
                  width: 120, 
                  height: 120, 
                  borderRadius: '50%', 
                  background: profileImage ? '#fff' : 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                  display: 'flex',
                  alignItems: 'center',
                  justifyContent: 'center',
                  fontSize: 48,
                  position: 'relative',
                  boxShadow: '0 8px 24px rgba(0,0,0,0.12)',
                  overflow: 'hidden'
                }}>
                  {profileImage ? (
                    <img src={profileImage} alt="Profile" style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                  ) : (
                    '👤'
                  )}
                </div>
                
                {/* Image Upload Button */}
                <label 
                  htmlFor="profileImageInput"
                  style={{ 
                    position: 'absolute',
                    bottom: 0,
                    right: 0,
                    background: '#2563eb',
                    color: '#fff',
                    width: 40,
                    height: 40,
                    borderRadius: '50%',
                    display: 'flex',
                    alignItems: 'center',
                    justifyContent: 'center',
                    cursor: 'pointer',
                    fontSize: 20,
                    border: '3px solid #fff',
                    boxShadow: '0 4px 12px rgba(37, 99, 235, 0.3)',
                    transition: 'all 0.3s ease'
                  }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.background = '#1d4ed8';
                    e.currentTarget.style.transform = 'scale(1.1)';
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.background = '#2563eb';
                    e.currentTarget.style.transform = 'scale(1)';
                  }}
                >
                  �
                </label>
                <input 
                  id="profileImageInput"
                  type="file" 
                  accept="image/*"
                  onChange={handleProfileImageUpload}
                  style={{ display: 'none' }}
                />
              </div>
              
              <h2 style={{ fontWeight: 700, fontSize: 26, marginBottom: 4, color: '#1f2937' }}>
                {user.firstName} {user.lastName}
              </h2>
              <p style={{ fontSize: 14, color: '#6b7280', marginBottom: 0 }}>Customer Profile</p>
            </div>
            
            {/* Details Card - Single Line Clean Format */}
            <div style={{ background: '#f9fafb', borderRadius: 14, padding: 20, marginBottom: 20 }}>
              {/* Email */}
              <div style={{ marginBottom: 12, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <div style={{ fontSize: 12, fontWeight: 700, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  📧 Email
                </div>
                <p style={{ fontSize: 14, color: '#1f2937', margin: 0, fontWeight: 500 }}>
                  {user.email || 'Not provided'}
                </p>
              </div>
              
              {/* Phone */}
              <div style={{ marginBottom: 12, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <div style={{ fontSize: 12, fontWeight: 700, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  📞 Phone
                </div>
                <p style={{ fontSize: 14, color: '#1f2937', margin: 0, fontWeight: 500 }}>
                  {user.phone || 'Not provided'}
                </p>
              </div>
              
              {/* Address */}
              <div style={{ marginBottom: 12, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <div style={{ fontSize: 12, fontWeight: 700, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  📍 Address
                </div>
                <p style={{ fontSize: 14, color: '#1f2937', margin: 0, fontWeight: 500 }}>
                  {user.address || 'Not provided'}
                </p>
              </div>
              
              {/* City */}
              <div style={{ marginBottom: 12, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <div style={{ fontSize: 12, fontWeight: 700, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  🏙️ City
                </div>
                <p style={{ fontSize: 14, color: '#1f2937', margin: 0, fontWeight: 500 }}>
                  {user.city || 'Not provided'}
                </p>
              </div>
              
              {/* Country */}
              <div style={{ marginBottom: 12, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <div style={{ fontSize: 12, fontWeight: 700, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  🌍 Country
                </div>
                <p style={{ fontSize: 14, color: '#1f2937', margin: 0, fontWeight: 500 }}>
                  {user.country || 'Not provided'}
                </p>
              </div>
              
              {/* Zip/Postcode */}
              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                <div style={{ fontSize: 12, fontWeight: 700, color: '#9ca3af', textTransform: 'uppercase', letterSpacing: '0.5px' }}>
                  📮 Zip/Postcode
                </div>
                <p style={{ fontSize: 14, color: '#1f2937', margin: 0, fontWeight: 500 }}>
                  {user.postcode || 'Not provided'}
                </p>
              </div>
