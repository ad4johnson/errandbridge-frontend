  // AI Title suggestions state
  const [titleSuggestions, setTitleSuggestions] = useState([]);
  const [showTitleSuggestions, setShowTitleSuggestions] = useState(false);
  const [titleLoading, setTitleLoading] = useState(false);

  async function handleAISuggest() {
    if (!note.trim()) {
      setAiError("Please enter a description first");
      setTimeout(() => setAiError(""), 3000);
      return;
    }

    setAiLoading(true);
    setAiError("");

    try {
      const response = await fetch("http://localhost:8001/prompt/ai-suggest", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          description: note.trim(),
          template_id: template
        })
      });

      if (!response.ok) throw new Error("Failed to get AI suggestion");

      const data = await response.json();
      
      // Track if template was auto-detected
      let templateChanged = false;
      
      // Update with AI suggestions
      if (data.title) {
        console.log("AI suggested title:", data.title);
      }
      if (data.description) {
        setNote(data.description);
      }
      if (data.suggested_template && data.suggested_template !== template) {
        setTemplate(data.suggested_template);
        templateChanged = true;
      }
      
      // Show success message with template info if it changed
      if (templateChanged) {
        setAiError(`✅ AI enhanced your description & suggested template: ${data.suggested_template}`);
        setTimeout(() => setAiError(""), 4000);
      }
    } catch (err) {
      setAiError("AI suggestion failed. Using your original description.");
      console.error("AI suggest error:", err);
    } finally {
      setAiLoading(false);
    }
  }

  async function handleAITitleSuggest() {
    if (!note.trim()) {
      setAiError("Please enter a description first");
      setTimeout(() => setAiError(""), 3000);
      return;
    }

    setTitleLoading(true);
    setAiError("");

    try {
      const response = await fetch("http://localhost:8001/prompt/ai-suggest", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          description: note.trim(),
          template_id: template,
          suggest_titles_only: true
        })
      });

      if (!response.ok) throw new Error("Failed to get AI title suggestions");

      const data = await response.json();
      
      // Parse title suggestions - could be array or string with newlines
      let suggestions = [];
      if (Array.isArray(data.title_suggestions)) {
        suggestions = data.title_suggestions.filter(t => t && t.trim()).slice(0, 5);
      } else if (data.title_suggestions && typeof data.title_suggestions === 'string') {
        suggestions = data.title_suggestions
          .split('\n')
          .map(t => t.replace(/^\d+\.\s*/, '').trim())
          .filter(t => t && t.length > 5 && t.length < 150)
          .slice(0, 5);
      } else if (data.title) {
        suggestions = [data.title];
      }

      if (suggestions.length > 0) {
        setTitleSuggestions(suggestions);
        setShowTitleSuggestions(true);
      } else {
        setAiError("No title suggestions generated. Try a more detailed description.");
        setTimeout(() => setAiError(""), 3000);
      }
    } catch (err) {
      setAiError("Title suggestion failed. Try again.");
      console.error("AI title suggest error:", err);
    } finally {
      setTitleLoading(false);
    }
  }

