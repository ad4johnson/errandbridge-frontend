# Example Capacitor live-reload config (DO NOT COMMIT a real .env.capacitor)
#
# When CAPACITOR_SERVER_URL is set, the native shells will load the web app from
# that URL instead of the bundled `build/` assets.
#
# iOS Simulator:
# CAPACITOR_SERVER_URL=http://localhost:3000
#
# Android Emulator:
# CAPACITOR_SERVER_URL=http://10.0.2.2:3000
#
# Physical device (replace with your Mac's LAN IP):
# CAPACITOR_SERVER_URL=http://192.168.1.42:3000
