# Example only — DO NOT COMMIT a real `.env.production.local`.
#
# CRA loads `.env.production.local` automatically during `react-scripts build`.
# Keeping a real one checked in can accidentally ship builds that point at a
# developer machine (e.g., 10.0.2.2:8001) instead of production.
#
# If you intentionally want a one-off local-backend native build (Android Studio
# emulator / iOS Simulator), copy this file to `.env.production.local` locally
# (it is gitignored via `.env*.local`) and uncomment what you need.
#
# -----------------------------------------------------------------------------
# Option A (recommended): Use LAN IP for a real device
# -----------------------------------------------------------------------------
# REACT_APP_USE_DEVICE_API=true
# REACT_APP_DEVICE_API_BASE=http://<your-mac-lan-ip>:8001
#
# -----------------------------------------------------------------------------
# Option B: Simulator/emulator loopback
# -----------------------------------------------------------------------------
# IMPORTANT: Do not ship Play/App Store builds with these enabled.
#
# Force local API base for Capacitor builds:
# REACT_APP_FORCE_API_BASE=true
#
# iOS Simulator loopback (host machine):
# REACT_APP_CAPACITOR_API_BASE_IOS=http://127.0.0.1:8001
#
# Android emulator host bridge (host machine):
# REACT_APP_CAPACITOR_API_BASE_ANDROID=http://10.0.2.2:8001
#
# -----------------------------------------------------------------------------
# Option C: Hosted API (production default)
# -----------------------------------------------------------------------------
# This is already the default for production builds; only needed for clarity.
# REACT_APP_CAPACITOR_USE_HOSTED_API=true
