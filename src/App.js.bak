      if (authCity) cache.setUserField('city', authCity);
      if (authCountry) cache.setUserField('country', authCountry);
      if (authPostcode) cache.setUserField('postcode', authPostcode);
    }, 500); // Debounce for 500ms
    
    return () => clearTimeout(timer);
  }, [authEmail, authFirstName, authLastName, authPhone, authAddressLine, authCity, authCountry, authPostcode]);

