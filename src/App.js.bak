          title,
          template,
          note,
          sensitivity,
          pickup,
          dropoff,
          agreed,
        });
        console.log('[CACHE] Errand form auto-saved');
      }
    }, 1000); // Debounce for 1 second
    
    return () => clearTimeout(timer);
  }, [title, template, note, sensitivity, pickup, dropoff, agreed]);

