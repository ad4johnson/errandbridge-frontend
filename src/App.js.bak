const PUZZLES = [
  { q: "What has keys but can't open locks?", a: "A piano" },
  { q: "What has a heart that doesn’t beat?", a: "An artichoke" },
  { q: "What comes once in a minute, twice in a moment, but never in a thousand years?", a: "The letter M" },
  { q: "What can travel around the world while staying in a corner?", a: "A stamp" },
  { q: "What gets wetter as it dries?", a: "A towel" },
  { q: "What has a neck but no head?", a: "A bottle" },
  { q: "What belongs to you but others use it more than you do?", a: "Your name" },
  { q: "What has hands but can’t clap?", a: "A clock" },
  { q: "What can you catch but not throw?", a: "A cold" },
  { q: "What has an eye but cannot see?", a: "A needle" },
  { q: "What is always in front of you but can’t be seen?", a: "The future" },
  { q: "What goes up but never comes down?", a: "Your age" },
  { q: "What has one head, one foot, and four legs?", a: "A bed" },
  { q: "What gets bigger the more you take away?", a: "A hole" },
  { q: "What has many teeth but can’t bite?", a: "A comb" },
  { q: "What runs but never walks?", a: "Water" },
  { q: "What can fill a room but takes up no space?", a: "Light" },
  { q: "What kind of band never plays music?", a: "A rubber band" },
  { q: "What has a thumb and four fingers but is not alive?", a: "A glove" },
  { q: "What has words but never speaks?", a: "A book" },
  { q: "What has a bottom at the top?", a: "Your legs" },
];

function getRandomPuzzleIdx(excludeIdx) {
  let idx;
  do {
    idx = Math.floor(Math.random() * PUZZLES.length);
  } while (idx === excludeIdx);
  return idx;
}

function App() {
  // Removed unused: toast, showToast, authAddress, files, editMode
  // Removed unused: toast, showToast, authAddress, files, editMode
  // Removed unused: toast, showToast, authAddress, files, editMode
  // Removed unused: toast, showToast, authAddress, files, editMode
  const [errands, setErrands] = useState([]);
  const [detailsModal, setDetailsModal] = useState({ open: false, errand: null });
  const [uploadedFiles, setUploadedFiles] = useState([]); // For transparency
  const [selectedErrands, setSelectedErrands] = useState([]);
  const [selectAll, setSelectAll] = useState(false);
  const [expandedErrandId, setExpandedErrandId] = useState(null); // For collapsible rows
  const [errandsSectionMinimized, setErrandsSectionMinimized] = useState(false); // For minimize/maximize
  
  // Delete a single errand by ID
  async function handleDeleteErrand(id) {
    // Show confirmation dialog
    const confirmDelete = window.confirm('Are you sure you want to delete this errand? This action cannot be undone.');
    if (!confirmDelete) return;
    
    const mutation = `mutation DeleteErrand($id: Int!) { deleteErrand(id: $id) }`;
    try {
      const token = localStorage.getItem('authToken');
      const headers = { 'Content-Type': 'application/json' };
      if (token) {
        headers['Authorization'] = `Bearer ${token}`;
        console.log(`[DELETE] Errand ${id} - Using auth token: ${token.substring(0, 30)}...`);
      } else {
        console.warn(`[DELETE] Errand ${id} - NO AUTH TOKEN FOUND IN LOCALSTORAGE`);
      }
      
      console.log(`[DELETE] Sending delete mutation for errand ${id}`);
      const response = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers,
        body: JSON.stringify({ query: mutation, variables: { id } })
      });
      
      const data = await response.json();
      console.log(`[DELETE] Response status: ${response.status}`);
      console.log(`[DELETE] Response data:`, data);
      
      if (data.errors) {
        console.error(`[DELETE] GraphQL error:`, data.errors);
        alert(`Failed to delete errand: ${data.errors[0]?.message || 'Unknown error'}`);
        return;
      }
      
      console.log(`[DELETE] ✅ Errand ${id} deleted successfully`);
      alert('Errand deleted successfully');
      fetchErrands();
    } catch (err) {
      console.error('[DELETE] Network error:', err);
      alert('Failed to delete errand. Please try again.');
    }
  }

  // Delete all selected errands
  async function handleDeleteSelected() {
    if (selectedErrands.length === 0) {
      alert('Please select at least one errand to delete');
      return;
    }
    
    const confirmDelete = window.confirm(`Are you sure you want to delete ${selectedErrands.length} errand(s)? This action cannot be undone.`);
    if (!confirmDelete) return;
    
    console.log(`[DELETE] Deleting ${selectedErrands.length} selected errands:`, selectedErrands);
    let successCount = 0;
    let failureCount = 0;
    
    for (const id of selectedErrands) {
      try {
        const token = localStorage.getItem('authToken');
        const headers = { 'Content-Type': 'application/json' };
        if (token) {
          headers['Authorization'] = `Bearer ${token}`;
        }
        
        const mutation = `mutation DeleteErrand($id: Int!) { deleteErrand(id: $id) }`;
        const response = await fetch('http://localhost:8001/graphql', {
          method: 'POST',
          headers,
          body: JSON.stringify({ query: mutation, variables: { id } })
        });
        
        const data = await response.json();
        
        if (data.data && data.data.deleteErrand === true) {
          console.log(`[DELETE] ✅ Errand ${id} deleted successfully`);
          successCount++;
        } else if (data.errors) {
          console.error(`[DELETE] ❌ Failed to delete errand ${id}:`, data.errors);
          failureCount++;
        }
      } catch (err) {
        console.error(`[DELETE] Network error for errand ${id}:`, err);
        failureCount++;
      }
    }
    
    const message = failureCount === 0 
      ? `✅ Successfully deleted ${successCount} errand(s)`
      : `⚠️ Deleted ${successCount} errand(s), failed to delete ${failureCount}`;
    
    console.log(`[DELETE] ${message}`);
    alert(message);
    
    setSelectedErrands([]);
    setSelectAll(false);
    fetchErrands();
  }

  // Handle edit errand
  function handleEditErrand(errand) {
    setEditingErrand(errand);
    setEditFormData({
      title: errand.title,
      note: errand.note,
      sensitivity: errand.sensitivity,
      pickupLocation: errand.pickupLocation,
      dropoffLocation: errand.dropoffLocation,
      template: errand.template || 'Official Document / Office Pickup'
    });
    setEditModalOpen(true);
  }

  function handleSaveEdit() {
    if (!editingErrand) return;
    
    const mutation = `
      mutation UpdateErrand($id: Int!, $title: String, $description: String, $templateId: String, $sensitivity: String, $pickupLocation: String, $dropoffLocation: String, $note: String) {
        updateErrand(input: { id: $id, title: $title, description: $description, templateId: $templateId, sensitivity: $sensitivity, pickupLocation: $pickupLocation, dropoffLocation: $dropoffLocation, note: $note }) {
          id
          title
          description
          templateId
          sensitivity
          pickupLocation
          dropoffLocation
          note
          status
        }
      }
    `;

    const token = localStorage.getItem('authToken');
    if (!token) {
      alert('❌ Error: Not logged in. Please log in first.');
      return;
    }

    fetch('http://localhost:8001/graphql', {
      method: 'POST',
      headers: { 
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`
      },
      body: JSON.stringify({
        query: mutation,
        variables: {
          id: editingErrand.id,
          title: editFormData.title,
          description: editFormData.note,
          templateId: editFormData.template,
          sensitivity: editFormData.sensitivity,
          pickupLocation: editFormData.pickupLocation,
          dropoffLocation: editFormData.dropoffLocation,
          note: editFormData.note
        }
      })
    })
    .then(res => res.json())
    .then(data => {
      if (data.errors) {
        alert('❌ Error updating errand:\n' + data.errors.map(e => e.message).join('\n'));
        console.error('GraphQL errors:', data.errors);
      } else if (data.data && data.data.updateErrand) {
        setAiError('✅ Errand updated successfully!');
        setTimeout(() => setAiError(''), 3000);
        fetchErrands(); // Refresh the errands list
        setEditModalOpen(false);
        setEditingErrand(null);
      }
    })
    .catch(err => {
      alert('❌ Error: ' + err.message);
      console.error('Fetch error:', err);
    });
  }

  // Handle assign errand to admin
  async function handleAssignErrand(errandId) {
    const mutation = `mutation { assignErrand(errandId: ${errandId}) { id status assignedTo assignedAt } }`;
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        return;
      }
      
      const response = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ query: mutation })
      });
      
      const data = await response.json();
      if (data.errors) {
        alert(`Error assigning errand: ${data.errors[0]?.message || 'Unknown error'}`);
        return;
      }
      
      if (data.data && data.data.assignErrand) {
        alert('✅ Errand assigned to you!');
        fetchErrands();
      }
    } catch (err) {
      console.error('Error assigning errand:', err);
      alert('Failed to assign errand. Please try again.');
    }
  }

  // Handle mark errand as done
  async function handleMarkDone(errandId) {
    const confirmDone = window.confirm('Mark this errand as completed?');
    if (!confirmDone) return;
    
    const mutation = `mutation { markErrandDone(errandId: ${errandId}) { id status reviewStatus } }`;
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        return;
      }
      
      const response = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ query: mutation })
      });
      
      const data = await response.json();
      if (data.errors) {
        alert(`Error marking errand as done: ${data.errors[0]?.message || 'Unknown error'}`);
        return;
      }
      
      if (data.data && data.data.markErrandDone) {
        alert('✅ Errand marked as completed!');
        
        // If current user is the customer, open review modal
        const errand = errands.find(e => e.id === errandId);
        if (errand && errand.userId === parseInt(localStorage.getItem('userId'))) {
          setReviewErrand(data.data.markErrandDone);
          setReviewModalOpen(true);
          setReviewRating(5);
          setReviewNotes('');
        }
        
        fetchErrands();
      }
    } catch (err) {
      console.error('Error marking errand as done:', err);
      alert('Failed to mark errand as done. Please try again.');
    }
  }

  // Handle submit review
  async function handleSubmitReview() {
    if (!reviewErrand) return;
    
    setReviewSubmitting(true);
    const mutation = `
      mutation {
        submitErrandReview(errandId: ${reviewErrand.id}, rating: ${reviewRating}, notes: "${reviewNotes.replace(/"/g, '\\"')}")  {
          id reviewStatus reviewerRating reviewCompletedAt
        }
      }
    `;
    
    try {
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      if (!token) {
        alert('Not authenticated');
        setReviewSubmitting(false);
        return;
      }
      
      const response = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ query: mutation })
      });
      
      const data = await response.json();
      if (data.errors) {
        alert(`Error submitting review: ${data.errors[0]?.message || 'Unknown error'}`);
        setReviewSubmitting(false);
        return;
      }
      
      if (data.data && data.data.submitErrandReview) {
        alert('✅ Thank you for your review!');
        setReviewModalOpen(false);
        setReviewErrand(null);
        setReviewRating(5);
        setReviewNotes('');
        fetchErrands();
      }
      setReviewSubmitting(false);
    } catch (err) {
      console.error('Error submitting review:', err);
      alert('Failed to submit review. Please try again.');
      setReviewSubmitting(false);
    }
  }

  // Handle select all toggle
  function handleSelectAll(e) {
    const checked = e.target.checked;
    setSelectAll(checked);
    if (checked) {
      setSelectedErrands(errands.map(e => e.id));
    } else {
      setSelectedErrands([]);
    }
  }

  // Handle individual checkbox toggle
  function handleSelectErrand(id) {
    setSelectedErrands(prev =>
      prev.includes(id) ? prev.filter(eid => eid !== id) : [...prev, id]
    );
  }
  // Removed unused: toast, showToast, authAddress, files, editMode

  // Fetch errands on load and after submit
  async function fetchErrands() {
    const query = `query { errands { id referenceNumber title status pickupLocation dropoffLocation sensitivity createdAt note attachments { id filename contentType sizeBytes createdAt } history { eventType oldStatus newStatus createdAt userId } } }`;
    try {
      // Check cache first - returns null if expired or missing
      const cachedErrands = await cache.getAPIResponse('errands_list');
      if (cachedErrands) {
        console.log('[FETCH_ERRANDS] Using cached errands list (from 2-minute cache)');
        setErrands(cachedErrands);
        const allFiles = cachedErrands.flatMap(e => (e.attachments || []));
        setUploadedFiles(allFiles);
        // Still fetch fresh data in background without blocking UI
        // This gives user instant results while updating data
      } else {
        console.log('[FETCH_ERRANDS] Cache miss, fetching fresh data from server');
      }
      
      const token = localStorage.getItem('authToken') || cache.getAuthToken();
      console.log('[FETCH_ERRANDS] Token from cache/localStorage:', token ? `${token.substring(0, 50)}...` : 'NO TOKEN FOUND');
      console.log('[FETCH_ERRANDS] All localStorage keys:', Object.keys(localStorage));
      
      const headers = { 'Content-Type': 'application/json' };
      if (token) {
        headers['Authorization'] = `Bearer ${token}`;
        console.log('[FETCH_ERRANDS] Authorization header set');
      } else {
        console.log('[FETCH_ERRANDS] ⚠️ NO TOKEN - Sending request WITHOUT auth header');
      }
      
      console.log('[FETCH_ERRANDS] Sending GraphQL query to http://localhost:8001/graphql');
      console.log('[FETCH_ERRANDS] Headers:', headers);
      
      const res = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers,
        body: JSON.stringify({ query })
      });
      
      const data = await res.json();
      console.log('[FETCH_ERRANDS] GraphQL response status:', res.status);
      console.log('[FETCH_ERRANDS] GraphQL response data:', data);
      
      if (data.data && data.data.errands) {
        console.log(`[FETCH_ERRANDS] ✅ Got ${data.data.errands.length} errand(s)`);
        setErrands(data.data.errands);
        // Cache the errands for 2 minutes to reduce server load
        await cache.setAPIResponse('errands_list', data.data.errands, 2 * 60 * 1000);
        // Collect all uploaded files for transparency
        const allFiles = data.data.errands.flatMap(e => (e.attachments || []));
        setUploadedFiles(allFiles);
      } else {
        console.log('[FETCH_ERRANDS] ❌ No errands data in response');
        setErrands([]);
      }
    } catch (err) {
      console.error('[FETCH_ERRANDS] Error:', err);
    }
  }

  // Helper function to get status badge styling
  function getStatusBadge(status) {
    const badges = {
      'pending': { bg: '#fef3c7', color: '#92400e', icon: '⏳' },
      'assigned': { bg: '#dbeafe', color: '#0c4a6e', icon: '👤' },
      'submitted': { bg: '#e0e7ff', color: '#312e81', icon: '✓' },
      'completed': { bg: '#dcfce7', color: '#166534', icon: '✅' },
      'cancelled': { bg: '#fee2e2', color: '#7f1d1d', icon: '✕' }
    };
    return badges[status] || { bg: '#f3f4f6', color: '#374151', icon: '•' };
  }

  React.useEffect(() => { fetchErrands(); }, []);

  // Load user profile data from backend and populate form fields
  async function loadUserProfile() {
    const token = localStorage.getItem('authToken') || cache.getAuthToken();
    if (!token) return;
    
    try {
      const res = await fetch('http://localhost:8001/auth/me', {
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        }
      });
      
      if (res.ok) {
        const data = await res.json();
        console.log('[USER PROFILE] Full response from /auth/me:', data);
        console.log('[USER PROFILE] is_admin field:', data.is_admin);
        
        // Populate form fields with user data
        if (data.first_name) setAuthFirstName(data.first_name);
        if (data.last_name) setAuthLastName(data.last_name);
        if (data.phone) setAuthPhone(data.phone);
        if (data.address_line1) setAuthAddressLine(data.address_line1);
        if (data.city) setAuthCity(data.city);
        if (data.country) setAuthCountry(data.country);
        if (data.postal_code) setAuthPostcode(data.postal_code);
        if (data.email) setAuthEmail(data.email);
        
        // Check if user is admin
        console.log('[USER PROFILE] Checking admin status:', { is_admin: data.is_admin, email: data.email });
        if (data.is_admin === true) {
          console.log('[USER PROFILE] ✅ User IS admin! Setting userIsAdmin to true');
          setUserIsAdmin(true);
        } else {
          console.log('[USER PROFILE] ⚠️ User is NOT admin (is_admin =', data.is_admin + ')');
          setUserIsAdmin(false);
        }
        
        // Cache user profile for next login
        cache.setUserProfile({
          firstName: data.first_name,
          lastName: data.last_name,
          phone: data.phone,
          address: data.address_line1,
          city: data.city,
          country: data.country,
          postcode: data.postal_code,
          email: data.email
        });
        
        // Also save to localStorage for settings persistence
        localStorage.setItem('userProfile', JSON.stringify({
          firstName: data.first_name,
          lastName: data.last_name,
          phone: data.phone,
          addressLine: data.address_line1,
          city: data.city,
          country: data.country,
          postcode: data.postal_code,
          email: data.email
        }));
      }
    } catch (err) {
      console.error('[USER PROFILE] Error loading profile:', err);
    }
  }

  async function handleSubmitErrand() {
    if (!title || !agreed) return;
    const token = localStorage.getItem('authToken');
    if (!token) {
      alert('Please log in first');
      setAuthModalOpen(true);
      return;
    }
    
    const mutation = `mutation CreateErrand($input: CreateErrandInput!) { createErrand(input: $input) { id title status referenceNumber } }`;
    const variables = {
      input: {
        title,
        note,
        templateId: null, // or template if you have an ID
        sensitivity,
        pickupLocation: pickup,
        dropoffLocation: dropoff,
        userId: user && user.id ? parseInt(user.id, 10) : null  // ← Ensure userId is an integer
      }
    };
    try {
      console.log('Submitting errand with variables:', variables);
      const res = await fetch('http://localhost:8001/graphql', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({ query: mutation, variables })
      });
      const data = await res.json();
      console.log('Errand submission response:', data);
      if (!data.errors && data.data && data.data.createErrand && data.data.createErrand.id) {
        const errandId = data.data.createErrand.id;
        const refNumber = data.data.createErrand.referenceNumber || errandId;
        
        // ✅ SHOW SUBMISSION CONFIRMATION MODAL IMMEDIATELY
        setSubmittedErrandData({
          id: errandId,
          title: title,
          referenceNumber: refNumber,
          status: data.data.createErrand.status || 'PENDING'
        });
        setSubmissionConfirmOpen(true);
        
        // ✅ SHOW SUCCESS MESSAGE
        setToast(`✅ Errand "${title}" submitted successfully! Reference: ${refNumber}`);
        
        // Upload files if any
        if (window.uploadedFilesInput && window.uploadedFilesInput.files && window.uploadedFilesInput.files.length > 0) {
          const numFiles = window.uploadedFilesInput.files.length;
          console.log(`[UPLOAD] Uploading ${numFiles} file(s)...`);
          
          for (let i = 0; i < window.uploadedFilesInput.files.length; i++) {
            const file = window.uploadedFilesInput.files[i];
            const formData = new FormData();
            formData.append('file', file);
            // Use XMLHttpRequest to ensure Authorization header is sent
            await new Promise((resolve, reject) => {
              const xhr = new window.XMLHttpRequest();
              xhr.open('POST', `http://localhost:8001/errands/${errandId}/attachments`);
              xhr.setRequestHeader('Authorization', `Bearer ${token}`);
              xhr.onload = function () {
                if (xhr.status >= 200 && xhr.status < 300) {
                  console.log(`[UPLOAD] File ${i + 1}/${numFiles} (${file.name}) uploaded successfully`);
                  resolve();
                } else {
                  console.error(`[UPLOAD] File ${i + 1} failed with status ${xhr.status}`);
                  reject(xhr.statusText);
                }
              };
              xhr.onerror = function () { 
                console.error(`[UPLOAD] File ${i + 1} network error`);
                reject(xhr.statusText); 
              };
              xhr.send(formData);
            });
          }
          console.log(`[UPLOAD] All ${numFiles} file(s) uploaded! Refreshing errand data...`);
        }
        // Refresh errands to get updated file counts
        await new Promise(resolve => setTimeout(resolve, 500)); // Small delay to ensure backend processes
